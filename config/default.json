{
  "baseline_strategy_module": "strategies.baseline_strategy",
  "current_strategy_module": "strategies.current_strategy",
  "experiments_dir": "experiments",
  "max_rounds": 5,
  "datasets": {
    "train": "data/train/sample_markets.csv",
    "validation": "data/validation/sample_markets.csv",
    "holdout": "data/holdout/sample_markets.csv"
  },
  "policy": {
    "min_trade_count": 20,
    "min_ev_improvement": 0.01,
    "max_drawdown_worsening": 0.01,
    "max_slippage_worsening": 0.005
  },
  "holdout_policy": {
    "enabled": true,
    "min_trade_count": 1,
    "min_ev_delta": -0.01,
    "max_drawdown_worsening": 0.02,
    "max_slippage_worsening": 0.005
  },
  "strategy_path": "strategies/current_strategy.py",
  "strategy_modifier": "fixed_patch_stub",
  "stop_on_repeated_proposal": true,
  "memory_filter": {
    "failed_patch_threshold": 2,
    "failed_direction_threshold": 3,
    "fallback_modifiers": [
      "adaptive_stub",
      "conservative_stub"
    ]
  },
  "exploration": {
    "stop_after_no_improvement_rounds": 3,
    "min_probe_ev_delta": 0.0,
    "min_validation_ev_delta": 0.0,
    "explore_after_no_improvement_rounds": 2,
    "explore_low_sample_threshold": 1,
    "explore_bonus": 12
  },
  "codex_cli": {
    "executable": "codex",
    "model": "default",
    "sandbox": "workspace-write",
    "workspace_root": "workspaces",
    "execute": false,
    "timeout_seconds": 120
  },
  "stub": {
    "old_threshold": "MIN_EDGE = 0.05",
    "new_threshold": "MIN_EDGE = 0.04"
  }
}
