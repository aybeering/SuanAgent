{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Attempts Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "attempt_count",
    "selected_attempt_id",
    "attempts_dir",
    "attempts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_attempts_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_count": {
      "type": "integer"
    },
    "selected_attempt_id": {
      "type": "string"
    },
    "attempts_dir": {
      "type": "string"
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "attempt_id",
          "attempt_index",
          "role",
          "agent_role",
          "profile_name",
          "adapter_name",
          "supported_directions",
          "direction_capability",
          "direction_intent_alignment",
          "runner_name",
          "runner",
          "agent_name",
          "direction_tag",
          "status",
          "selected",
          "candidate_score",
          "failure_stage",
          "failure_code",
          "failure_message",
          "reason_codes",
          "patch_sha256",
          "attempt_dir",
          "agent_input",
          "attempt_output",
          "files"
        ],
        "properties": {
          "attempt_id": {
            "type": "string"
          },
          "attempt_index": {
            "type": "integer"
          },
          "role": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "profile_name": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "supported_directions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "direction_capability": {
            "type": "object"
          },
          "direction_intent_alignment": {
            "type": "object"
          },
          "runner_name": {
            "type": "string"
          },
          "runner": {
            "type": "object"
          },
          "agent_name": {
            "type": "string"
          },
          "direction_tag": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "selected": {
            "type": "boolean"
          },
          "candidate_score": {
            "type": "number"
          },
          "failure_stage": {
            "type": "string"
          },
          "failure_code": {
            "type": "string"
          },
          "failure_message": {
            "type": "string"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "stage",
                "code",
                "message"
              ],
              "properties": {
                "stage": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "patch_sha256": {
            "type": "string"
          },
          "attempt_dir": {
            "type": "string"
          },
          "agent_input": {
            "type": "string"
          },
          "attempt_output": {
            "type": "string"
          },
          "files": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "path",
                "name",
                "bytes",
                "sha256"
              ],
              "properties": {
                "path": {
                  "type": "string"
                },
                "name": {
                  "type": "string"
                },
                "bytes": {
                  "type": "integer"
                },
                "sha256": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    }
  }
}
