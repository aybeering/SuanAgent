{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Bundle Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "round_index",
    "agent_name",
    "input_bundle_dir",
    "output_bundle_dir",
    "input_files",
    "output_files",
    "policy",
    "source_round_dir"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_bundle_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "round_index": {
      "type": "integer"
    },
    "agent_name": {
      "type": "string"
    },
    "input_bundle_dir": {
      "type": "string"
    },
    "output_bundle_dir": {
      "type": "string"
    },
    "input_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "name",
          "bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "bytes": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "output_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "name",
          "bytes",
          "sha256"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "bytes": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "input_bundle_read_only",
        "output_bundle_write_only_for_external_agents",
        "strategy_changes_must_be_patch_only"
      ],
      "properties": {
        "input_bundle_read_only": {
          "type": "boolean"
        },
        "output_bundle_write_only_for_external_agents": {
          "type": "boolean"
        },
        "strategy_changes_must_be_patch_only": {
          "type": "boolean"
        }
      }
    },
    "source_round_dir": {
      "type": "string"
    }
  }
}
