{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Execution Audit",
  "type": "object",
  "required": [
    "schema_version",
    "runner_name",
    "agent_name",
    "profile_name",
    "adapter_name",
    "status",
    "execution_enabled",
    "command",
    "command_sha256",
    "cwd",
    "workspace_path",
    "agent_input_path",
    "workspace_output_path",
    "round_output_path",
    "timeout_seconds",
    "returncode",
    "stdout",
    "stderr",
    "stdin",
    "raw_response",
    "output_file",
    "round_output_file",
    "allowed_mutation_paths",
    "mutation_errors",
    "mutation_guard",
    "intake_binding",
    "preflight_binding"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_execution_v1"
      ]
    },
    "runner_name": {
      "type": "string",
      "enum": [
        "agent_contract_runner_v1",
        "codex_cli_guarded_adapter"
      ]
    },
    "agent_name": {
      "type": "string"
    },
    "profile_name": {
      "type": "string"
    },
    "adapter_name": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "disabled",
        "completed",
        "command_failed",
        "timeout",
        "workspace_violation"
      ]
    },
    "execution_enabled": {
      "type": "boolean"
    },
    "command": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "command_sha256": {
      "type": "string"
    },
    "cwd": {
      "type": "string"
    },
    "workspace_path": {
      "type": "string"
    },
    "agent_input_path": {
      "type": "string"
    },
    "workspace_output_path": {
      "type": "string"
    },
    "round_output_path": {
      "type": "string"
    },
    "timeout_seconds": {
      "type": "integer"
    },
    "returncode": {
      "type": [
        "integer",
        "null"
      ]
    },
    "stdout": {
      "$ref_note": "stream summary",
      "type": "object",
      "required": [
        "chars",
        "sha256",
        "preview"
      ],
      "properties": {
        "chars": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        }
      }
    },
    "stderr": {
      "$ref_note": "stream summary",
      "type": "object",
      "required": [
        "chars",
        "sha256",
        "preview"
      ],
      "properties": {
        "chars": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        }
      }
    },
    "stdin": {
      "$ref_note": "stream summary",
      "type": "object",
      "required": [
        "chars",
        "sha256",
        "preview"
      ],
      "properties": {
        "chars": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        }
      }
    },
    "raw_response": {
      "$ref_note": "stream summary",
      "type": "object",
      "required": [
        "chars",
        "sha256",
        "preview"
      ],
      "properties": {
        "chars": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        },
        "preview": {
          "type": "string"
        }
      }
    },
    "output_file": {
      "$ref_note": "file summary",
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "round_output_file": {
      "$ref_note": "file summary",
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "allowed_mutation_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mutation_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "mutation_guard": {
      "type": "object",
      "required": [
        "allowed_paths",
        "mutation_errors",
        "passed"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "mutation_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "passed": {
          "type": "boolean"
        }
      }
    },
    "intake_binding": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "bound",
        "agent_validation_path",
        "proposal_path",
        "raw_agent_output_path",
        "agent_validation_ok",
        "proposal_patch_sha256",
        "proposal_applicable",
        "checks",
        "blocking_reasons"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "agent_execution_intake_binding_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "unbound",
            "bound",
            "mismatch"
          ]
        },
        "bound": {
          "type": "boolean"
        },
        "agent_validation_path": {
          "type": "string"
        },
        "proposal_path": {
          "type": "string"
        },
        "raw_agent_output_path": {
          "type": "string"
        },
        "agent_validation_ok": {
          "type": "boolean"
        },
        "proposal_patch_sha256": {
          "type": "string"
        },
        "proposal_applicable": {
          "type": "boolean"
        },
        "checks": {
          "type": "object",
          "required": [
            "agent_validation_present",
            "proposal_present",
            "raw_agent_output_present",
            "validation_embeds_proposal",
            "validation_proposal_matches_saved_proposal",
            "audit_raw_response_matches_proposal",
            "raw_agent_output_matches_proposal",
            "audit_command_matches_proposal",
            "audit_command_sha256_matches_proposal",
            "audit_stdin_matches_proposal_prompt",
            "validation_patch_hash_matches_proposal",
            "validation_target_matches_proposal",
            "validation_applicable_matches_proposal",
            "validation_agent_input_matches_audit",
            "validation_agent_output_matches_raw_path"
          ],
          "properties": {
            "agent_validation_present": {
              "type": "boolean"
            },
            "proposal_present": {
              "type": "boolean"
            },
            "raw_agent_output_present": {
              "type": "boolean"
            },
            "validation_embeds_proposal": {
              "type": "boolean"
            },
            "validation_proposal_matches_saved_proposal": {
              "type": "boolean"
            },
            "audit_raw_response_matches_proposal": {
              "type": "boolean"
            },
            "raw_agent_output_matches_proposal": {
              "type": "boolean"
            },
            "audit_command_matches_proposal": {
              "type": "boolean"
            },
            "audit_command_sha256_matches_proposal": {
              "type": "boolean"
            },
            "audit_stdin_matches_proposal_prompt": {
              "type": "boolean"
            },
            "validation_patch_hash_matches_proposal": {
              "type": "boolean"
            },
            "validation_target_matches_proposal": {
              "type": "boolean"
            },
            "validation_applicable_matches_proposal": {
              "type": "boolean"
            },
            "validation_agent_input_matches_audit": {
              "type": "boolean"
            },
            "validation_agent_output_matches_raw_path": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "preflight_binding": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "bound",
        "preflight_path",
        "preflight_file",
        "profile_name",
        "operator_unlock_ready",
        "canary_exempt",
        "expected_command_sha256",
        "expected_workspace_prefix",
        "checks",
        "blocking_reasons"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "agent_execution_preflight_binding_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "unbound",
            "bound",
            "mismatch"
          ]
        },
        "bound": {
          "type": "boolean"
        },
        "preflight_path": {
          "type": "string"
        },
        "preflight_file": {
          "$ref": "#/$defs/file_record"
        },
        "profile_name": {
          "type": "string"
        },
        "operator_unlock_ready": {
          "type": "boolean"
        },
        "canary_exempt": {
          "type": "boolean"
        },
        "expected_command_sha256": {
          "type": "string"
        },
        "expected_workspace_prefix": {
          "type": "string"
        },
        "checks": {
          "type": "object",
          "required": [
            "preflight_present",
            "profile_present",
            "adapter_is_codex_cli",
            "command_matches_preflight",
            "command_sha256_matches_preflight",
            "workspace_path_under_preflight_prefix",
            "allowed_mutation_paths_strategy_only",
            "mutation_guard_paths_strategy_only",
            "execution_allowed_by_startup_preflight"
          ],
          "properties": {
            "preflight_present": {
              "type": "boolean"
            },
            "profile_present": {
              "type": "boolean"
            },
            "adapter_is_codex_cli": {
              "type": "boolean"
            },
            "command_matches_preflight": {
              "type": "boolean"
            },
            "command_sha256_matches_preflight": {
              "type": "boolean"
            },
            "workspace_path_under_preflight_prefix": {
              "type": "boolean"
            },
            "allowed_mutation_paths_strategy_only": {
              "type": "boolean"
            },
            "mutation_guard_paths_strategy_only": {
              "type": "boolean"
            },
            "execution_allowed_by_startup_preflight": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
