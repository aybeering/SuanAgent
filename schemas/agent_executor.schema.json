{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Executor Report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "attempt_count",
    "selected_attempt_id",
    "execution_policy",
    "attempts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_executor_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_count": {
      "type": "integer"
    },
    "selected_attempt_id": {
      "type": "string"
    },
    "execution_policy": {
      "type": "object",
      "required": [
        "mode",
        "queue_order",
        "attempt_id_source",
        "acceptance",
        "max_candidates",
        "per_agent_timeout_seconds",
        "allow_disabled_adapters"
      ],
      "properties": {
        "mode": {
          "type": "string"
        },
        "queue_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "attempt_id_source": {
          "type": "string"
        },
        "acceptance": {
          "type": "string"
        },
        "max_candidates": {
          "type": "integer"
        },
        "per_agent_timeout_seconds": {
          "type": "integer"
        },
        "allow_disabled_adapters": {
          "type": "boolean"
        }
      }
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "attempt_id",
          "attempt_index",
          "role",
          "agent_role",
          "profile_name",
          "adapter_name",
          "supported_directions",
          "direction_capability",
          "direction_intent_alignment",
          "runner",
          "modifier_name",
          "agent_name",
          "direction_tag",
          "status",
          "selected",
          "candidate_score",
          "score_reasons",
          "quality_breakdown",
          "failure_stage",
          "failure_code",
          "validation_status",
          "proposal",
          "artifacts"
        ],
        "properties": {
          "attempt_id": {
            "type": "string"
          },
          "attempt_index": {
            "type": "integer"
          },
          "role": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "profile_name": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "supported_directions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "direction_capability": {
            "type": "object"
          },
          "direction_intent_alignment": {
            "type": "object"
          },
          "runner": {
            "type": "object"
          },
          "modifier_name": {
            "type": "string"
          },
          "agent_name": {
            "type": "string"
          },
          "direction_tag": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "selected": {
            "type": "boolean"
          },
          "candidate_score": {
            "type": "number"
          },
          "score_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "quality_breakdown": {
            "type": "object"
          },
          "failure_stage": {
            "type": "string"
          },
          "failure_code": {
            "type": "string"
          },
          "validation_status": {
            "type": "string"
          },
          "proposal": {
            "type": "object",
            "required": [
              "applicable",
              "patch_sha256",
              "workspace_path",
              "command",
              "prompt_chars",
              "raw_response_chars",
              "contract_errors"
            ],
            "properties": {
              "applicable": {
                "type": "boolean"
              },
              "patch_sha256": {
                "type": "string",
                "pattern": "^$|^[a-f0-9]{64}$"
              },
              "workspace_path": {
                "type": "string"
              },
              "command": {
                "type": "array"
              },
              "prompt_chars": {
                "type": "integer"
              },
              "raw_response_chars": {
                "type": "integer"
              },
              "contract_errors": {
                "type": "array"
              }
            }
          },
          "artifacts": {
            "type": "object",
            "required": [
              "attempt_dir",
              "workspace_manifest",
              "agent_execution"
            ],
            "properties": {
              "attempt_dir": {
                "type": "string"
              },
              "workspace_manifest": {
                "type": "string"
              },
              "agent_execution": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
