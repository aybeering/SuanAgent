{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Golden Replay",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "reason_codes",
    "failure_stage",
    "failure_code",
    "failure_message",
    "run_id",
    "round_id",
    "round_dir",
    "requested_attempt_id",
    "attempt_id",
    "selected_attempt_id",
    "agent",
    "checks",
    "artifacts",
    "comparison",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_golden_replay_v1"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "code",
          "message"
        ],
        "properties": {
          "stage": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "failure_stage": {
      "type": "string"
    },
    "failure_code": {
      "type": "string"
    },
    "failure_message": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "round_id": {
      "type": "string"
    },
    "round_dir": {
      "type": "string"
    },
    "requested_attempt_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "selected_attempt_id": {
      "type": "string"
    },
    "agent": {
      "type": "string"
    },
    "checks": {
      "type": "object",
      "required": [
        "attempt_present",
        "replayed_output_validation_ok",
        "patch_sha_matches_saved_proposal",
        "raw_output_sha_matches_saved_output",
        "direction_tag_matches_saved_proposal"
      ],
      "properties": {
        "attempt_present": {
          "type": "boolean"
        },
        "replayed_output_validation_ok": {
          "type": "boolean"
        },
        "patch_sha_matches_saved_proposal": {
          "type": "boolean"
        },
        "raw_output_sha_matches_saved_output": {
          "type": "boolean"
        },
        "direction_tag_matches_saved_proposal": {
          "type": "boolean"
        }
      }
    },
    "artifacts": {
      "type": "object"
    },
    "comparison": {
      "type": "object",
      "required": [
        "saved_patch_sha256",
        "replayed_patch_sha256",
        "saved_raw_output_sha256",
        "replayed_raw_output_sha256",
        "saved_direction_tag",
        "replayed_direction_tag"
      ],
      "properties": {
        "saved_patch_sha256": {
          "type": "string"
        },
        "replayed_patch_sha256": {
          "type": "string"
        },
        "saved_raw_output_sha256": {
          "type": "string"
        },
        "replayed_raw_output_sha256": {
          "type": "string"
        },
        "saved_direction_tag": {
          "type": "string"
        },
        "replayed_direction_tag": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "does_not_execute_external_agents",
        "does_not_select_candidate",
        "does_not_apply_final_patch",
        "does_not_change_acceptance",
        "replays_saved_agent_input_contract",
        "requires_replayed_output_validation",
        "requires_patch_hash_match",
        "requires_raw_output_hash_match"
      ],
      "properties": {
        "does_not_execute_external_agents": {
          "type": "boolean"
        },
        "does_not_select_candidate": {
          "type": "boolean"
        },
        "does_not_apply_final_patch": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "replays_saved_agent_input_contract": {
          "type": "boolean"
        },
        "requires_replayed_output_validation": {
          "type": "boolean"
        },
        "requires_patch_hash_match": {
          "type": "boolean"
        },
        "requires_raw_output_hash_match": {
          "type": "boolean"
        }
      }
    }
  }
}
