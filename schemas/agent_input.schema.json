{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Input Contract",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "round_index",
    "target_file",
    "target_file_content",
    "target_file_sha256",
    "round_dir",
    "artifacts",
    "metrics_before",
    "policy",
    "candidate_selection",
    "modifiers",
    "output_contract"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_io_input_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "round_index": {
      "type": "integer"
    },
    "target_file": {
      "type": "string",
      "minLength": 1
    },
    "target_file_content": {
      "type": "string"
    },
    "target_file_sha256": {
      "type": "string",
      "minLength": 64
    },
    "round_dir": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "object",
      "required": [
        "agent_context_markdown",
        "agent_context_json",
        "train_report_before",
        "validation_report_before",
        "holdout_report_before"
      ],
      "properties": {
        "agent_context_markdown": {
          "type": "string"
        },
        "agent_context_json": {
          "type": "string"
        },
        "train_report_before": {
          "type": "string"
        },
        "validation_report_before": {
          "type": "string"
        },
        "holdout_report_before": {
          "type": "string"
        },
        "champion_registry": {
          "type": "string"
        },
        "previous_champion_comparison": {
          "type": "string"
        }
      }
    },
    "metrics_before": {
      "type": "object",
      "required": [
        "train",
        "validation",
        "holdout"
      ],
      "properties": {
        "train": {
          "type": "object"
        },
        "validation": {
          "type": "object"
        },
        "holdout": {
          "type": "object"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "validation",
        "holdout"
      ],
      "properties": {
        "validation": {
          "type": "object"
        },
        "holdout": {
          "type": "object"
        }
      }
    },
    "candidate_selection": {
      "type": "object"
    },
    "modifiers": {
      "type": "object",
      "required": [
        "primary",
        "fallbacks"
      ],
      "properties": {
        "primary": {
          "type": "string"
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "output_contract": {
      "type": "object",
      "required": [
        "schema_version",
        "proposal_protocol_version",
        "expected_output_path",
        "required_artifacts"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "agent_io_output_v1"
          ]
        },
        "proposal_protocol_version": {
          "type": "string",
          "enum": [
            "proposal_v1"
          ]
        },
        "expected_output_path": {
          "type": "string"
        },
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
