{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Input Contract",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "round_index",
    "target_file",
    "target_file_content",
    "target_file_sha256",
    "round_dir",
    "input_bundle_dir",
    "output_bundle_dir",
    "artifacts",
    "metrics_before",
    "policy",
    "candidate_selection",
    "strategy_search_space",
    "agent_roles",
    "agent_profiles",
    "active_agent",
    "modifiers",
    "output_contract"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_io_input_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "round_index": {
      "type": "integer"
    },
    "target_file": {
      "type": "string",
      "minLength": 1
    },
    "target_file_content": {
      "type": "string"
    },
    "target_file_sha256": {
      "type": "string",
      "minLength": 64
    },
    "round_dir": {
      "type": "string",
      "minLength": 1
    },
    "input_bundle_dir": {
      "type": "string",
      "minLength": 1
    },
    "output_bundle_dir": {
      "type": "string",
      "minLength": 1
    },
    "artifacts": {
      "type": "object",
      "required": [
        "agent_context_markdown",
        "agent_role_contracts",
        "analysis_notes_json",
        "analysis_notes_markdown",
        "visual_artifacts_manifest",
        "visual_review_json",
        "visual_review_markdown",
        "agent_execution_plan_json",
        "agent_execution_plan_markdown",
        "chart_html",
        "trade_timeline_html",
        "agent_context_json",
        "proposal_intent_json",
        "proposal_intent_markdown",
        "train_report_before",
        "validation_report_before",
        "holdout_report_before"
      ],
      "properties": {
        "agent_role_contracts": {
          "type": "string"
        },
        "analysis_notes_json": {
          "type": "string"
        },
        "analysis_notes_markdown": {
          "type": "string"
        },
        "visual_artifacts_manifest": {
          "type": "string"
        },
        "visual_review_json": {
          "type": "string"
        },
        "visual_review_markdown": {
          "type": "string"
        },
        "agent_execution_plan_json": {
          "type": "string"
        },
        "agent_execution_plan_markdown": {
          "type": "string"
        },
        "chart_html": {
          "type": "string"
        },
        "trade_timeline_html": {
          "type": "string"
        },
        "agent_context_markdown": {
          "type": "string"
        },
        "agent_context_json": {
          "type": "string"
        },
        "proposal_intent_json": {
          "type": "string"
        },
        "proposal_intent_markdown": {
          "type": "string"
        },
        "train_report_before": {
          "type": "string"
        },
        "validation_report_before": {
          "type": "string"
        },
        "holdout_report_before": {
          "type": "string"
        },
        "champion_registry": {
          "type": "string"
        },
        "previous_champion_comparison": {
          "type": "string"
        }
      }
    },
    "metrics_before": {
      "type": "object",
      "required": [
        "train",
        "validation",
        "holdout"
      ],
      "properties": {
        "train": {
          "type": "object"
        },
        "validation": {
          "type": "object"
        },
        "holdout": {
          "type": "object"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "validation",
        "holdout"
      ],
      "properties": {
        "validation": {
          "type": "object"
        },
        "holdout": {
          "type": "object"
        }
      }
    },
    "candidate_selection": {
      "type": "object"
    },
    "strategy_search_space": {
      "type": "object",
      "required": [
        "schema_version",
        "directions",
        "direction_order",
        "fallback_direction",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "strategy_search_space_v1"
          ]
        },
        "directions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "direction_tag",
              "description",
              "preferred_after",
              "avoid_after",
              "modifier_hint"
            ],
            "properties": {
              "direction_tag": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "preferred_after": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "avoid_after": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "modifier_hint": {
                "type": "string"
              }
            }
          }
        },
        "direction_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_direction": {
          "type": "string"
        },
        "policy": {
          "type": "object",
          "required": [
            "advisory_only",
            "does_not_route_agents",
            "does_not_change_acceptance"
          ],
          "properties": {
            "advisory_only": {
              "type": "boolean"
            },
            "does_not_route_agents": {
              "type": "boolean"
            },
            "does_not_change_acceptance": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "agent_roles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role_name",
          "stage",
          "enabled",
          "execution_mode",
          "required",
          "implemented",
          "description",
          "allowed_adapters",
          "consumes",
          "produces",
          "decision_authority"
        ],
        "properties": {
          "role_name": {
            "type": "string"
          },
          "stage": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "execution_mode": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "implemented": {
            "type": "boolean"
          },
          "description": {
            "type": "string"
          },
          "allowed_adapters": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "consumes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "produces": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "decision_authority": {
            "type": "string"
          }
        }
      }
    },
    "agent_profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "profile_name",
          "adapter_name",
          "role",
          "agent_role",
          "enabled",
          "settings",
          "runner"
        ],
        "properties": {
          "profile_name": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "enabled": {
            "type": "boolean"
          },
          "settings": {
            "type": "object"
          },
          "runner": {
            "type": "object"
          }
        }
      }
    },
    "active_agent": {
      "type": "object",
      "required": [
        "attempt_id",
        "role",
        "agent_role",
        "profile_name",
        "adapter_name",
        "agent_name",
        "output_filename"
      ],
      "properties": {
        "attempt_id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "agent_role": {
          "type": "string"
        },
        "profile_name": {
          "type": "string"
        },
        "adapter_name": {
          "type": "string"
        },
        "agent_name": {
          "type": "string"
        },
        "output_filename": {
          "type": "string"
        }
      }
    },
    "modifiers": {
      "type": "object",
      "required": [
        "primary",
        "fallbacks"
      ],
      "properties": {
        "primary": {
          "type": "string"
        },
        "fallbacks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "output_contract": {
      "type": "object",
      "required": [
        "schema_version",
        "proposal_protocol_version",
        "expected_output_path",
        "expected_raw_output_path",
        "allowed_output_paths",
        "workspace_output_path",
        "expected_command_output_filename",
        "required_artifacts"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "agent_io_output_v1"
          ]
        },
        "proposal_protocol_version": {
          "type": "string",
          "enum": [
            "proposal_v1"
          ]
        },
        "expected_output_path": {
          "type": "string"
        },
        "expected_raw_output_path": {
          "type": "string"
        },
        "allowed_output_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "workspace_output_path": {
          "type": "string"
        },
        "expected_command_output_filename": {
          "type": "string"
        },
        "required_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
