{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Output Contract",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "round_index",
    "selected_role",
    "selected_agent_role",
    "selection_reason",
    "proposal_intent_summary",
    "selected_proposal",
    "attempt_count",
    "attempts",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_io_output_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "round_index": {
      "type": "integer"
    },
    "selected_role": {
      "type": "string"
    },
    "selected_agent_role": {
      "type": "string"
    },
    "selection_reason": {
      "type": "string"
    },
    "proposal_intent_summary": {
      "$ref": "#/$defs/proposal_intent_summary"
    },
    "selected_proposal": {
      "type": "object",
      "required": [
        "protocol_version",
        "agent_name",
        "round_index",
        "target_file",
        "summary",
        "risk_notes",
        "expected_metric_change",
        "raw_response",
        "patch_diff",
        "applicable",
        "direction_tag",
        "hypotheses",
        "patch_sha256",
        "contract_errors"
      ],
      "properties": {
        "protocol_version": {
          "type": "string",
          "enum": [
            "proposal_v1"
          ]
        },
        "agent_name": {
          "type": "string"
        },
        "round_index": {
          "type": "integer"
        },
        "target_file": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "risk_notes": {
          "type": "string"
        },
        "expected_metric_change": {
          "type": "object"
        },
        "raw_response": {
          "type": "string"
        },
        "patch_diff": {
          "type": "string"
        },
        "applicable": {
          "type": "boolean"
        },
        "direction_tag": {
          "type": "string"
        },
        "hypotheses": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "patch_sha256": {
          "type": "string"
        },
        "contract_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "attempt_count": {
      "type": "integer"
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "role",
          "agent_role",
          "profile_name",
          "adapter_name",
          "runner",
          "runner_name",
          "agent_name",
          "direction_tag",
          "direction_intent_alignment",
          "status",
          "selected",
          "candidate_score",
          "failure_stage",
          "failure_code",
          "failure_message",
          "reason_codes",
          "patch_sha256",
          "selection_reason"
        ],
        "properties": {
          "role": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "profile_name": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "runner": {
            "type": "object"
          },
          "runner_name": {
            "type": "string"
          },
          "agent_name": {
            "type": "string"
          },
          "direction_tag": {
            "type": "string"
          },
          "direction_intent_alignment": {
            "type": "object"
          },
          "status": {
            "type": "string"
          },
          "selected": {
            "type": "boolean"
          },
          "candidate_score": {
            "type": "number"
          },
          "quality_breakdown": {
            "type": "object"
          },
          "failure_stage": {
            "type": "string"
          },
          "failure_code": {
            "type": "string"
          },
          "failure_message": {
            "type": "string"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "stage",
                "code",
                "message"
              ],
              "properties": {
                "stage": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "patch_sha256": {
            "type": "string"
          },
          "selection_reason": {
            "type": "string"
          },
          "probe_ev_delta": {
            "type": "number"
          },
          "validation_ev_delta": {
            "type": [
              "number",
              "null"
            ]
          },
          "holdout_ev_delta": {
            "type": [
              "number",
              "null"
            ]
          },
          "champion_gap": {
            "type": "object"
          },
          "routing_prior": {
            "type": "object"
          }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "agent_input",
        "agent_bundle_manifest",
        "raw_agent_output",
        "proposal",
        "proposal_attempts",
        "agent_response",
        "patch"
      ],
      "properties": {
        "agent_input": {
          "type": "string"
        },
        "agent_bundle_manifest": {
          "type": "string"
        },
        "raw_agent_output": {
          "type": "string"
        },
        "proposal": {
          "type": "string"
        },
        "proposal_attempts": {
          "type": "string"
        },
        "agent_response": {
          "type": "string"
        },
        "patch": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "proposal_intent_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "source_schema_version",
        "recommended_direction",
        "avoid_directions",
        "reason",
        "evidence",
        "trace_schema_version",
        "selection_reason_code",
        "selected_direction",
        "fallback_direction",
        "exhausted_known_directions",
        "candidate_order",
        "candidate_rows",
        "avoid_source_summary",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "proposal_intent_summary_v1"
          ]
        },
        "source_schema_version": {
          "type": "string"
        },
        "recommended_direction": {
          "type": "string"
        },
        "avoid_directions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trace_schema_version": {
          "type": "string"
        },
        "selection_reason_code": {
          "type": "string"
        },
        "selected_direction": {
          "type": "string"
        },
        "fallback_direction": {
          "type": "string"
        },
        "exhausted_known_directions": {
          "type": "boolean"
        },
        "candidate_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "direction_tag",
              "rank",
              "selected",
              "in_avoid_directions",
              "avoid_sources",
              "reason",
              "modifier_hint"
            ],
            "properties": {
              "direction_tag": {
                "type": "string"
              },
              "rank": {
                "type": "integer",
                "minimum": 0
              },
              "selected": {
                "type": "boolean"
              },
              "in_avoid_directions": {
                "type": "boolean"
              },
              "avoid_sources": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "modifier_hint": {
                "type": "string"
              }
            }
          }
        },
        "avoid_source_summary": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "policy": {
          "type": "object",
          "required": [
            "advisory_only",
            "does_not_route_agents",
            "does_not_change_acceptance"
          ],
          "properties": {
            "advisory_only": {
              "type": "boolean",
              "const": true
            },
            "does_not_route_agents": {
              "type": "boolean",
              "const": true
            },
            "does_not_change_acceptance": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
