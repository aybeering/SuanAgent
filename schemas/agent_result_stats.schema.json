{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Result Stats",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "source_path",
    "generated_at",
    "totals",
    "agents",
    "directions",
    "patch_families",
    "routing_hints"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_result_stats_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "totals": {
      "type": "object",
      "required": [
        "attempt_count",
        "selected_count",
        "selectable_count",
        "accepted_count",
        "rejected_count"
      ],
      "properties": {
        "attempt_count": {
          "type": "integer"
        },
        "selected_count": {
          "type": "integer"
        },
        "selectable_count": {
          "type": "integer"
        },
        "accepted_count": {
          "type": "integer"
        },
        "rejected_count": {
          "type": "integer"
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "directions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "patch_families": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "routing_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_type",
          "target",
          "action",
          "reason",
          "top_failure_code",
          "attempt_count",
          "accepted_count"
        ],
        "properties": {
          "target_type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "top_failure_code": {
            "type": "string"
          },
          "attempt_count": {
            "type": "integer"
          },
          "accepted_count": {
            "type": "integer"
          }
        }
      }
    }
  }
}
