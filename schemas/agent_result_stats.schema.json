{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Result Stats",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "source_path",
    "generated_at",
    "totals",
    "agents",
    "directions",
    "patch_families",
    "routing_hints"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_result_stats_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "source_path": {
      "type": "string",
      "minLength": 1
    },
    "generated_at": {
      "type": "string",
      "minLength": 1
    },
    "totals": {
      "type": "object",
      "required": [
        "attempt_count",
        "selected_count",
        "selectable_count",
        "accepted_count",
        "rejected_count"
      ],
      "properties": {
        "attempt_count": {
          "type": "integer"
        },
        "selected_count": {
          "type": "integer"
        },
        "selectable_count": {
          "type": "integer"
        },
        "accepted_count": {
          "type": "integer"
        },
        "rejected_count": {
          "type": "integer"
        }
      }
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "directions": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "patch_families": {
      "type": "array",
      "items": {
        "type": "object"
      }
    },
    "routing_hints": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "target_type",
          "target",
          "action",
          "reason",
          "top_failure_code",
          "attempt_count",
          "accepted_count"
        ],
        "properties": {
          "target_type": {
            "type": "string"
          },
          "target": {
            "type": "string"
          },
          "action": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "top_failure_code": {
            "type": "string"
          },
          "attempt_count": {
            "type": "integer"
          },
          "accepted_count": {
            "type": "integer"
          }
        }
      }
    },
    "round_replays": {
      "type": "object",
      "required": [
        "round_count",
        "replayed_round_count",
        "missing_round_count",
        "ok_count",
        "failure_count",
        "rounds"
      ],
      "properties": {
        "round_count": {
          "type": "integer"
        },
        "replayed_round_count": {
          "type": "integer"
        },
        "missing_round_count": {
          "type": "integer"
        },
        "ok_count": {
          "type": "integer"
        },
        "failure_count": {
          "type": "integer"
        },
        "rounds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "round_id",
              "exists",
              "ok",
              "failure_code",
              "failure_stage",
              "path",
              "markdown_path",
              "planned_attempt_count",
              "manifest_attempt_count",
              "replayed_attempt_count",
              "selected_attempt_id",
              "attempts"
            ],
            "properties": {
              "round_id": {
                "type": "string"
              },
              "exists": {
                "type": "boolean"
              },
              "ok": {
                "type": "boolean"
              },
              "failure_code": {
                "type": "string"
              },
              "failure_stage": {
                "type": "string"
              },
              "path": {
                "type": "string"
              },
              "markdown_path": {
                "type": "string"
              },
              "planned_attempt_count": {
                "type": "integer"
              },
              "manifest_attempt_count": {
                "type": "integer"
              },
              "replayed_attempt_count": {
                "type": "integer"
              },
              "selected_attempt_id": {
                "type": "string"
              },
              "attempts": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": [
                    "attempt_id",
                    "profile_name",
                    "adapter_name",
                    "runner_name",
                    "selected",
                    "ok",
                    "failure_code",
                    "plan_matches_manifest",
                    "replay_path"
                  ],
                  "properties": {
                    "attempt_id": {
                      "type": "string"
                    },
                    "profile_name": {
                      "type": "string"
                    },
                    "adapter_name": {
                      "type": "string"
                    },
                    "runner_name": {
                      "type": "string"
                    },
                    "selected": {
                      "type": "boolean"
                    },
                    "ok": {
                      "type": "boolean"
                    },
                    "failure_code": {
                      "type": "string"
                    },
                    "plan_matches_manifest": {
                      "type": "boolean"
                    },
                    "replay_path": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
