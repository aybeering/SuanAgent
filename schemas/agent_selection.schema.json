{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Selection Report",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "selected_attempt_id",
    "selection_policy",
    "attempts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_selection_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "selected_attempt_id": {
      "type": "string"
    },
    "selection_policy": {
      "type": "object",
      "required": [
        "eligible_status",
        "rank_order",
        "final_acceptance"
      ],
      "properties": {
        "eligible_status": {
          "type": "string"
        },
        "rank_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "final_acceptance": {
          "type": "string"
        }
      }
    },
    "attempts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "attempt_id",
          "attempt_index",
          "role",
          "agent_name",
          "direction_tag",
          "status",
          "eligible",
          "selected",
          "rank",
          "candidate_score",
          "failure_stage",
          "failure_code",
          "failure_message",
          "reason_codes",
          "score_reasons",
          "blocking_reasons",
          "selection_reason",
          "skip_reason",
          "patch_sha256",
          "probe_ev_delta",
          "validation_status",
          "attempt_dir"
        ],
        "properties": {
          "attempt_id": {
            "type": "string"
          },
          "attempt_index": {
            "type": "integer"
          },
          "role": {
            "type": "string"
          },
          "agent_name": {
            "type": "string"
          },
          "direction_tag": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "eligible": {
            "type": "boolean"
          },
          "selected": {
            "type": "boolean"
          },
          "rank": {
            "type": "integer"
          },
          "candidate_score": {
            "type": "number"
          },
          "failure_stage": {
            "type": "string"
          },
          "failure_code": {
            "type": "string"
          },
          "failure_message": {
            "type": "string"
          },
          "reason_codes": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "stage",
                "code",
                "message"
              ],
              "properties": {
                "stage": {
                  "type": "string"
                },
                "code": {
                  "type": "string"
                },
                "message": {
                  "type": "string"
                }
              }
            }
          },
          "score_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "blocking_reasons": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "selection_reason": {
            "type": "string"
          },
          "skip_reason": {
            "type": "string"
          },
          "patch_sha256": {
            "type": "string"
          },
          "probe_ev_delta": {
            "type": "number"
          },
          "validation_status": {
            "type": "string"
          },
          "validation_accepted": {
            "type": [
              "boolean",
              "null"
            ]
          },
          "validation_ev_delta": {
            "type": [
              "number",
              "null"
            ]
          },
          "attempt_dir": {
            "type": "string"
          }
        }
      }
    }
  }
}
