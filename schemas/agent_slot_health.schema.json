{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Slot Health",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "source_artifacts",
    "totals",
    "status_counts",
    "slots",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_slot_health_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "agent_activation_preflight",
        "rounds"
      ],
      "properties": {
        "agent_activation_preflight": {
          "type": "string"
        },
        "rounds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "slot_count",
        "healthy_count",
        "needs_replay_count",
        "blocked_count",
        "workspace_required_count",
        "execution_audit_required_count",
        "replay_present_count"
      ],
      "properties": {
        "slot_count": {
          "type": "integer"
        },
        "healthy_count": {
          "type": "integer"
        },
        "needs_replay_count": {
          "type": "integer"
        },
        "blocked_count": {
          "type": "integer"
        },
        "workspace_required_count": {
          "type": "integer"
        },
        "execution_audit_required_count": {
          "type": "integer"
        },
        "replay_present_count": {
          "type": "integer"
        }
      }
    },
    "status_counts": {
      "type": "object"
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slot_id",
          "run_id",
          "round_id",
          "attempt_id",
          "attempt_index",
          "queue_role",
          "profile_name",
          "agent_role",
          "adapter_name",
          "runner_name",
          "execution_enabled",
          "activation_status",
          "health_status",
          "health_ok",
          "issues",
          "attempt_saved",
          "selected",
          "candidate_status",
          "candidate_failure_code",
          "workspace_required",
          "workspace_manifest_present",
          "workspace_manifest_path",
          "execution_audit_required",
          "agent_execution_present",
          "agent_execution_path",
          "agent_execution_status",
          "replay_present",
          "replay_ok",
          "plan_matches_manifest",
          "replay_path"
        ],
        "properties": {
          "slot_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "round_id": {
            "type": "string"
          },
          "attempt_id": {
            "type": "string"
          },
          "attempt_index": {
            "type": "integer"
          },
          "queue_role": {
            "type": "string"
          },
          "profile_name": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "runner_name": {
            "type": "string"
          },
          "execution_enabled": {
            "type": "boolean"
          },
          "activation_status": {
            "type": "string"
          },
          "health_status": {
            "type": "string"
          },
          "health_ok": {
            "type": "boolean"
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "attempt_saved": {
            "type": "boolean"
          },
          "selected": {
            "type": "boolean"
          },
          "candidate_status": {
            "type": "string"
          },
          "candidate_failure_code": {
            "type": "string"
          },
          "workspace_required": {
            "type": "boolean"
          },
          "workspace_manifest_present": {
            "type": "boolean"
          },
          "workspace_manifest_path": {
            "type": "string"
          },
          "execution_audit_required": {
            "type": "boolean"
          },
          "agent_execution_present": {
            "type": "boolean"
          },
          "agent_execution_path": {
            "type": "string"
          },
          "agent_execution_status": {
            "type": "string"
          },
          "replay_present": {
            "type": "boolean"
          },
          "replay_ok": {
            "type": "boolean"
          },
          "plan_matches_manifest": {
            "type": "boolean"
          },
          "replay_path": {
            "type": "string"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "does_not_execute_agents",
        "does_not_select_candidate",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_select_candidate": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  }
}
