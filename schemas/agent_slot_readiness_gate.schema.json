{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Slot Readiness Gate",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "ok",
    "source_artifacts",
    "totals",
    "status_counts",
    "slots",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_slot_readiness_gate_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "agent_activation_preflight",
        "rounds"
      ],
      "properties": {
        "agent_activation_preflight": {
          "type": "string"
        },
        "rounds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "slot_count",
        "ready_count",
        "blocked_count",
        "contract_only_count",
        "external_slot_count",
        "replay_required_count"
      ],
      "properties": {
        "slot_count": {
          "type": "integer"
        },
        "ready_count": {
          "type": "integer"
        },
        "blocked_count": {
          "type": "integer"
        },
        "contract_only_count": {
          "type": "integer"
        },
        "external_slot_count": {
          "type": "integer"
        },
        "replay_required_count": {
          "type": "integer"
        }
      }
    },
    "status_counts": {
      "type": "object"
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slot_id",
          "run_id",
          "round_id",
          "attempt_id",
          "attempt_index",
          "queue_role",
          "profile_name",
          "agent_role",
          "adapter_name",
          "runner_name",
          "execution_enabled",
          "external_slot",
          "activation_status",
          "readiness_status",
          "readiness_ok",
          "blocking_issues",
          "advisory_issues",
          "requirements",
          "paths"
        ],
        "properties": {
          "slot_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "round_id": {
            "type": "string"
          },
          "attempt_id": {
            "type": "string"
          },
          "attempt_index": {
            "type": "integer"
          },
          "queue_role": {
            "type": "string"
          },
          "profile_name": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "runner_name": {
            "type": "string"
          },
          "execution_enabled": {
            "type": "boolean"
          },
          "external_slot": {
            "type": "boolean"
          },
          "activation_status": {
            "type": "string"
          },
          "readiness_status": {
            "type": "string"
          },
          "readiness_ok": {
            "type": "boolean"
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "advisory_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requirements": {
            "type": "object"
          },
          "paths": {
            "type": "object"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "readiness_gate_only",
        "does_not_execute_agents",
        "does_not_select_candidate",
        "does_not_change_acceptance",
        "requires_replay",
        "deterministic_code_keeps_acceptance_authority"
      ],
      "properties": {
        "readiness_gate_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_select_candidate": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "requires_replay": {
          "type": "boolean"
        },
        "deterministic_code_keeps_acceptance_authority": {
          "type": "boolean"
        }
      }
    }
  }
}
