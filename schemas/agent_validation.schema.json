{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Agent Validation Report",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "errors",
    "warnings",
    "reason_codes",
    "failure_stage",
    "failure_code",
    "failure_message",
    "agent_input_path",
    "agent_output_path",
    "proposal_intent_summary",
    "expected_target_file",
    "expected_round_index",
    "proposal_protocol_version",
    "proposal_applicable",
    "proposal_target_file",
    "proposal_direction_tag",
    "proposal_patch_sha256",
    "semantic_checks",
    "intake_diagnosis",
    "checks",
    "consistency_checks",
    "proposal"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "agent_validation_v1"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "code",
          "message"
        ],
        "properties": {
          "stage": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "failure_stage": {
      "type": "string"
    },
    "failure_code": {
      "type": "string"
    },
    "failure_message": {
      "type": "string"
    },
    "agent_input_path": {
      "type": "string"
    },
    "agent_output_path": {
      "type": "string"
    },
    "proposal_intent_summary": {
      "$ref": "#/$defs/proposal_intent_summary"
    },
    "expected_target_file": {
      "type": "string"
    },
    "expected_round_index": {
      "type": "integer"
    },
    "proposal_protocol_version": {
      "type": "string"
    },
    "proposal_applicable": {
      "type": "boolean"
    },
    "proposal_target_file": {
      "type": "string"
    },
    "proposal_direction_tag": {
      "type": "string"
    },
    "proposal_patch_sha256": {
      "type": "string"
    },
    "semantic_checks": {
      "$ref": "#/$defs/semantic_checks"
    },
    "intake_diagnosis": {
      "$ref": "#/$defs/intake_diagnosis"
    },
    "checks": {
      "type": "object",
      "required": [
        "contract_valid",
        "git_apply_check",
        "git_apply_error",
        "strategy_only_patch"
      ],
      "properties": {
        "contract_valid": {
          "type": "boolean"
        },
        "git_apply_check": {
          "type": "string"
        },
        "git_apply_error": {
          "type": "string"
        },
        "strategy_only_patch": {
          "type": "boolean"
        }
      }
    },
    "consistency_checks": {
      "$ref": "#/$defs/consistency_checks"
    },
    "proposal": {
      "$ref": "strategy_proposal.schema.json#/$defs/strategy_proposal"
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "consistency_checks": {
      "type": "object",
      "required": [
        "agent_output_path",
        "proposal_patch_sha256",
        "checks",
        "blocking_reasons"
      ],
      "properties": {
        "agent_output_path": {
          "type": "string"
        },
        "proposal_patch_sha256": {
          "type": "string"
        },
        "checks": {
          "type": "object",
          "required": [
            "ok_matches_errors",
            "failure_code_matches_ok",
            "proposal_intent_matches_agent_input",
            "expected_round_matches_agent_input",
            "expected_target_matches_agent_input",
            "proposal_round_matches_expected",
            "proposal_target_matches_expected",
            "proposal_protocol_matches_top_level",
            "proposal_applicable_matches_top_level",
            "proposal_direction_matches_top_level",
            "proposal_patch_hash_matches_top_level",
            "patch_hash_matches_patch_diff",
            "raw_output_matches_proposal",
            "contract_check_matches_errors",
            "semantic_check_matches_contract_valid",
            "semantic_errors_match_report_contract_errors",
            "intake_diagnosis_matches_failure_metadata",
            "intake_diagnosis_codes_match_reason_codes",
            "git_apply_error_matches_errors",
            "strategy_only_matches_contract_errors"
          ],
          "properties": {
            "ok_matches_errors": {
              "type": "boolean"
            },
            "failure_code_matches_ok": {
              "type": "boolean"
            },
            "proposal_intent_matches_agent_input": {
              "type": "boolean"
            },
            "expected_round_matches_agent_input": {
              "type": "boolean"
            },
            "expected_target_matches_agent_input": {
              "type": "boolean"
            },
            "proposal_round_matches_expected": {
              "type": "boolean"
            },
            "proposal_target_matches_expected": {
              "type": "boolean"
            },
            "proposal_protocol_matches_top_level": {
              "type": "boolean"
            },
            "proposal_applicable_matches_top_level": {
              "type": "boolean"
            },
            "proposal_direction_matches_top_level": {
              "type": "boolean"
            },
            "proposal_patch_hash_matches_top_level": {
              "type": "boolean"
            },
            "patch_hash_matches_patch_diff": {
              "type": "boolean"
            },
            "raw_output_matches_proposal": {
              "type": "boolean"
            },
            "contract_check_matches_errors": {
              "type": "boolean"
            },
            "semantic_check_matches_contract_valid": {
              "type": "boolean"
            },
            "semantic_errors_match_report_contract_errors": {
              "type": "boolean"
            },
            "intake_diagnosis_matches_failure_metadata": {
              "type": "boolean"
            },
            "intake_diagnosis_codes_match_reason_codes": {
              "type": "boolean"
            },
            "git_apply_error_matches_errors": {
              "type": "boolean"
            },
            "strategy_only_matches_contract_errors": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        },
        "blocking_reasons": {
          "$ref": "#/$defs/string_array"
        }
      },
      "additionalProperties": false
    },
    "intake_diagnosis": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "primary_stage",
        "primary_code",
        "primary_message",
        "blocking_codes",
        "blocking_count",
        "retryable",
        "git_apply_status"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "agent_intake_diagnosis_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "blocked"
          ]
        },
        "primary_stage": {
          "type": "string"
        },
        "primary_code": {
          "type": "string"
        },
        "primary_message": {
          "type": "string"
        },
        "blocking_codes": {
          "$ref": "#/$defs/string_array"
        },
        "blocking_count": {
          "type": "integer"
        },
        "retryable": {
          "type": "boolean"
        },
        "git_apply_status": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "semantic_checks": {
      "type": "object",
      "required": [
        "schema_version",
        "ok",
        "errors",
        "checks"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "proposal_semantic_checks_v1"
          ]
        },
        "ok": {
          "type": "boolean"
        },
        "errors": {
          "$ref": "#/$defs/string_array"
        },
        "checks": {
          "type": "object",
          "required": [
            "preexisting_contract_errors_absent",
            "protocol_version_valid",
            "agent_name_present",
            "round_index_matches_expected",
            "target_file_matches_expected",
            "target_file_relative",
            "summary_present",
            "risk_notes_present",
            "raw_response_present",
            "direction_tag_present",
            "direction_tag_format_valid",
            "applicable_patch_present",
            "rejection_reason_present_when_not_applicable",
            "patch_targets_valid",
            "expected_metric_change_valid",
            "hypotheses_valid",
            "command_valid"
          ],
          "properties": {
            "preexisting_contract_errors_absent": {
              "type": "boolean"
            },
            "protocol_version_valid": {
              "type": "boolean"
            },
            "agent_name_present": {
              "type": "boolean"
            },
            "round_index_matches_expected": {
              "type": "boolean"
            },
            "target_file_matches_expected": {
              "type": "boolean"
            },
            "target_file_relative": {
              "type": "boolean"
            },
            "summary_present": {
              "type": "boolean"
            },
            "risk_notes_present": {
              "type": "boolean"
            },
            "raw_response_present": {
              "type": "boolean"
            },
            "direction_tag_present": {
              "type": "boolean"
            },
            "direction_tag_format_valid": {
              "type": "boolean"
            },
            "applicable_patch_present": {
              "type": "boolean"
            },
            "rejection_reason_present_when_not_applicable": {
              "type": "boolean"
            },
            "patch_targets_valid": {
              "type": "boolean"
            },
            "expected_metric_change_valid": {
              "type": "boolean"
            },
            "hypotheses_valid": {
              "type": "boolean"
            },
            "command_valid": {
              "type": "boolean"
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },
    "proposal_intent_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "source_schema_version",
        "recommended_direction",
        "avoid_directions",
        "reason",
        "evidence",
        "trace_schema_version",
        "selection_reason_code",
        "selected_direction",
        "fallback_direction",
        "exhausted_known_directions",
        "candidate_order",
        "candidate_rows",
        "avoid_source_summary",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "proposal_intent_summary_v1"
          ]
        },
        "source_schema_version": {
          "type": "string"
        },
        "recommended_direction": {
          "type": "string"
        },
        "avoid_directions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trace_schema_version": {
          "type": "string"
        },
        "selection_reason_code": {
          "type": "string"
        },
        "selected_direction": {
          "type": "string"
        },
        "fallback_direction": {
          "type": "string"
        },
        "exhausted_known_directions": {
          "type": "boolean"
        },
        "candidate_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "direction_tag",
              "rank",
              "selected",
              "in_avoid_directions",
              "avoid_sources",
              "reason",
              "modifier_hint"
            ],
            "properties": {
              "direction_tag": {
                "type": "string"
              },
              "rank": {
                "type": "integer",
                "minimum": 0
              },
              "selected": {
                "type": "boolean"
              },
              "in_avoid_directions": {
                "type": "boolean"
              },
              "avoid_sources": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "modifier_hint": {
                "type": "string"
              }
            }
          }
        },
        "avoid_source_summary": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "policy": {
          "type": "object",
          "required": [
            "advisory_only",
            "does_not_route_agents",
            "does_not_change_acceptance"
          ],
          "properties": {
            "advisory_only": {
              "type": "boolean",
              "const": true
            },
            "does_not_route_agents": {
              "type": "boolean",
              "const": true
            },
            "does_not_change_acceptance": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
