{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Attempt Output",
  "type": "object",
  "required": [
    "schema_version",
    "attempt_id",
    "attempt_index",
    "round_id",
    "role",
    "agent_role",
    "profile_name",
    "adapter_name",
    "supported_directions",
    "direction_capability",
    "direction_intent_alignment",
    "proposal_intent_summary",
    "runner_name",
    "runner",
    "agent_name",
    "direction_tag",
    "status",
    "selected",
    "eligible",
    "rank",
    "candidate_score",
    "failure_stage",
    "failure_code",
    "failure_message",
    "reason_codes",
    "proposal",
    "selection",
    "validation",
    "artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "attempt_output_v1"
      ]
    },
    "attempt_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_index": {
      "type": "integer"
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "role": {
      "type": "string"
    },
    "agent_role": {
      "type": "string"
    },
    "profile_name": {
      "type": "string"
    },
    "adapter_name": {
      "type": "string"
    },
    "supported_directions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "direction_capability": {
      "type": "object"
    },
    "direction_intent_alignment": {
      "type": "object"
    },
    "proposal_intent_summary": {
      "$ref": "#/$defs/proposal_intent_summary"
    },
    "runner_name": {
      "type": "string"
    },
    "runner": {
      "type": "object"
    },
    "agent_name": {
      "type": "string"
    },
    "direction_tag": {
      "type": "string"
    },
    "status": {
      "type": "string"
    },
    "selected": {
      "type": "boolean"
    },
    "eligible": {
      "type": "boolean"
    },
    "rank": {
      "type": "integer"
    },
    "candidate_score": {
      "type": "number"
    },
    "failure_stage": {
      "type": "string"
    },
    "failure_code": {
      "type": "string"
    },
    "failure_message": {
      "type": "string"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "code",
          "message"
        ],
        "properties": {
          "stage": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "proposal": {
      "type": "object"
    },
    "selection": {
      "type": "object",
      "required": [
        "selected",
        "selection_reason",
        "skip_reason",
        "score_reasons",
        "quality_breakdown",
        "blocking_reasons"
      ],
      "properties": {
        "selected": {
          "type": "boolean"
        },
        "selection_reason": {
          "type": "string"
        },
        "skip_reason": {
          "type": "string"
        },
        "score_reasons": {
          "type": "array"
        },
        "quality_breakdown": {
          "type": "object"
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "status",
        "accepted",
        "ev_delta",
        "probe_ev_delta"
      ],
      "properties": {
        "status": {
          "type": "string"
        },
        "accepted": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "ev_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "trade_count_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "probe_ev_delta": {
          "type": "number"
        },
        "probe_trade_count_delta": {
          "type": "number"
        },
        "holdout_ev_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "holdout_trade_count_delta": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "artifacts": {
      "type": "object",
      "required": [
        "attempt",
        "agent_input",
        "proposal",
        "raw_agent_output",
        "patch",
        "selection",
        "workspace_manifest",
        "agent_execution",
        "round_agent_input",
        "round_agent_output",
        "round_agent_validation"
      ],
      "properties": {
        "attempt": {
          "type": "string"
        },
        "agent_input": {
          "type": "string"
        },
        "proposal": {
          "type": "string"
        },
        "raw_agent_output": {
          "type": "string"
        },
        "patch": {
          "type": "string"
        },
        "selection": {
          "type": "string"
        },
        "workspace_manifest": {
          "type": "string"
        },
        "agent_execution": {
          "type": "string"
        },
        "round_agent_input": {
          "type": "string"
        },
        "round_agent_output": {
          "type": "string"
        },
        "round_agent_validation": {
          "type": "string"
        }
      }
    }
  },
  "$defs": {
    "proposal_intent_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "source_schema_version",
        "recommended_direction",
        "avoid_directions",
        "reason",
        "evidence",
        "trace_schema_version",
        "selection_reason_code",
        "selected_direction",
        "fallback_direction",
        "exhausted_known_directions",
        "candidate_order",
        "candidate_rows",
        "avoid_source_summary",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "proposal_intent_summary_v1"
          ]
        },
        "source_schema_version": {
          "type": "string"
        },
        "recommended_direction": {
          "type": "string"
        },
        "avoid_directions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reason": {
          "type": "string"
        },
        "evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "trace_schema_version": {
          "type": "string"
        },
        "selection_reason_code": {
          "type": "string"
        },
        "selected_direction": {
          "type": "string"
        },
        "fallback_direction": {
          "type": "string"
        },
        "exhausted_known_directions": {
          "type": "boolean"
        },
        "candidate_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "direction_tag",
              "rank",
              "selected",
              "in_avoid_directions",
              "avoid_sources",
              "reason",
              "modifier_hint"
            ],
            "properties": {
              "direction_tag": {
                "type": "string"
              },
              "rank": {
                "type": "integer",
                "minimum": 0
              },
              "selected": {
                "type": "boolean"
              },
              "in_avoid_directions": {
                "type": "boolean"
              },
              "avoid_sources": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "modifier_hint": {
                "type": "string"
              }
            }
          }
        },
        "avoid_source_summary": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "policy": {
          "type": "object",
          "required": [
            "advisory_only",
            "does_not_route_agents",
            "does_not_change_acceptance"
          ],
          "properties": {
            "advisory_only": {
              "type": "boolean",
              "const": true
            },
            "does_not_route_agents": {
              "type": "boolean",
              "const": true
            },
            "does_not_change_acceptance": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    }
  }
}
