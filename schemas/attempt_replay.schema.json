{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Attempt Replay Report",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "reason_codes",
    "failure_stage",
    "failure_code",
    "failure_message",
    "attempt_dir",
    "round_dir",
    "strategy_module",
    "validation",
    "probe"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "attempt_replay_v1"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "code",
          "message"
        ],
        "properties": {
          "stage": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "failure_stage": {
      "type": "string"
    },
    "failure_code": {
      "type": "string"
    },
    "failure_message": {
      "type": "string"
    },
    "attempt_dir": {
      "type": "string"
    },
    "round_dir": {
      "type": "string"
    },
    "strategy_module": {
      "type": "string"
    },
    "validation": {
      "type": "object"
    },
    "probe": {
      "type": "object",
      "required": [
        "ran",
        "ok",
        "reason_codes",
        "failure_stage",
        "failure_code",
        "failure_message"
      ],
      "properties": {
        "ran": {
          "type": "boolean"
        },
        "ok": {
          "type": "boolean"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "stage",
              "code",
              "message"
            ],
            "properties": {
              "stage": {
                "type": "string"
              },
              "code": {
                "type": "string"
              },
              "message": {
                "type": "string"
              }
            }
          }
        },
        "failure_stage": {
          "type": "string"
        },
        "failure_code": {
          "type": "string"
        },
        "failure_message": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "error": {
          "type": "string"
        },
        "metrics": {
          "type": "object"
        },
        "artifacts": {
          "type": "object"
        }
      }
    }
  }
}
