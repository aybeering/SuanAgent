{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Candidate Leaderboard Terminal Output",
  "type": "array",
  "items": {
    "type": "object",
    "required": [
      "run_id",
      "round_id",
      "attempt_id",
      "attempt_index",
      "selected",
      "status",
      "candidate_score",
      "quality_breakdown",
      "probe_ev_delta",
      "validation_status",
      "failure_stage",
      "failure_code",
      "reason_codes",
      "patch_sha256",
      "target_file"
    ],
    "properties": {
      "run_id": {
        "type": "string",
        "minLength": 1
      },
      "round_id": {
        "type": "string",
        "minLength": 1
      },
      "attempt_id": {
        "type": "string",
        "minLength": 1
      },
      "attempt_index": {
        "type": "integer",
        "minimum": 1
      },
      "role": {
        "type": "string"
      },
      "profile_name": {
        "type": "string"
      },
      "adapter_name": {
        "type": "string"
      },
      "runner_name": {
        "type": "string"
      },
      "agent_name": {
        "type": "string"
      },
      "direction_tag": {
        "type": "string"
      },
      "selected": {
        "type": "boolean"
      },
      "status": {
        "type": "string"
      },
      "candidate_score": {
        "type": "number"
      },
      "quality_breakdown": {
        "type": "object",
        "required": [
          "schema_version",
          "total_score",
          "signals"
        ],
        "properties": {
          "schema_version": {
            "type": "string",
            "enum": [
              "candidate_quality_v1"
            ]
          },
          "total_score": {
            "type": "number"
          },
          "signals": {
            "type": "object"
          }
        }
      },
      "probe_ev_delta": {
        "type": "number"
      },
      "probe_trade_count_delta": {
        "type": "number"
      },
      "validation_status": {
        "type": "string"
      },
      "validation_accepted": {
        "type": [
          "boolean",
          "null"
        ]
      },
      "failure_stage": {
        "type": "string"
      },
      "failure_code": {
        "type": "string"
      },
      "failure_message": {
        "type": "string"
      },
      "reason_codes": {
        "type": "array",
        "items": {
          "type": [
            "string",
            "object"
          ]
        }
      },
      "validation_ev_delta": {
        "type": [
          "number",
          "null"
        ]
      },
      "validation_trade_count_delta": {
        "type": [
          "number",
          "null"
        ]
      },
      "holdout_ev_delta": {
        "type": [
          "number",
          "null"
        ]
      },
      "holdout_trade_count_delta": {
        "type": [
          "number",
          "null"
        ]
      },
      "patch_sha256": {
        "type": "string",
        "pattern": "^$|^[a-f0-9]{64}$"
      },
      "summary": {
        "type": "string"
      },
      "target_file": {
        "type": "string"
      },
      "selection_reason": {
        "type": "string"
      },
      "score_reasons": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "contract_errors": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "memory_filter_reason": {
        "type": "string"
      },
      "patch_memory_filter_reason": {
        "type": "string"
      },
      "direction_filter_reason": {
        "type": "string"
      },
      "direction_prior": {
        "type": "object"
      },
      "exploration_bonus": {
        "type": "object"
      },
      "routing_prior": {
        "type": "object"
      },
      "champion_gap": {
        "type": "object"
      },
      "patch_check_error": {
        "type": "string"
      },
      "probe_error": {
        "type": "string"
      },
      "probe_artifacts": {
        "type": "object"
      }
    }
  }
}
