{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Champion Promotion Approval",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "operator_intent",
    "reviewed_command",
    "dry_run_summary",
    "approval_gate",
    "evidence_files",
    "recommended_next_actions",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "champion_promotion_approval_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "needs_dry_run",
        "ready_for_operator_review",
        "approval_blocked",
        "approval_recorded"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "operator_intent": {
      "type": "object",
      "required": [
        "approval_recorded",
        "explicit_approval",
        "operator_id",
        "required_confirmation_phrase_hash",
        "provided_confirmation_phrase_hash",
        "confirmation_phrase_matches"
      ],
      "properties": {
        "approval_recorded": {
          "type": "boolean"
        },
        "explicit_approval": {
          "type": "boolean"
        },
        "operator_id": {
          "type": "string"
        },
        "required_confirmation_phrase_hash": {
          "type": "string"
        },
        "provided_confirmation_phrase_hash": {
          "type": "string"
        },
        "confirmation_phrase_matches": {
          "type": "boolean"
        }
      }
    },
    "reviewed_command": {
      "type": "object",
      "required": [
        "command",
        "command_sha256",
        "promotion_authority",
        "source_dry_run_path",
        "source_dry_run_sha256"
      ],
      "properties": {
        "command": {
          "type": "string"
        },
        "command_sha256": {
          "type": "string"
        },
        "promotion_authority": {
          "type": "string"
        },
        "source_dry_run_path": {
          "type": "string"
        },
        "source_dry_run_sha256": {
          "type": "string"
        }
      }
    },
    "dry_run_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "ok",
        "would_promote",
        "blocking_reasons"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "would_promote": {
          "type": "boolean"
        },
        "blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "approval_gate": {
      "type": "object",
      "required": [
        "eligible_for_approval",
        "approval_blockers",
        "requires_operator_review",
        "requires_matching_confirmation_phrase",
        "requires_dry_run_recommendation",
        "requires_nonempty_reviewed_command"
      ],
      "properties": {
        "eligible_for_approval": {
          "type": "boolean"
        },
        "approval_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires_operator_review": {
          "type": "boolean"
        },
        "requires_matching_confirmation_phrase": {
          "type": "boolean"
        },
        "requires_dry_run_recommendation": {
          "type": "boolean"
        },
        "requires_nonempty_reviewed_command": {
          "type": "boolean"
        }
      }
    },
    "evidence_files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "exists",
          "sha256",
          "byte_count"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "exists": {
            "type": "boolean"
          },
          "sha256": {
            "type": "string"
          },
          "byte_count": {
            "type": "integer"
          }
        }
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_write_champion_registry",
        "does_not_append_champion_history",
        "does_not_execute_promote_command",
        "does_not_change_acceptance",
        "approval_does_not_promote",
        "promotion_still_requires_explicit_command"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "does_not_write_champion_registry": {
          "type": "boolean"
        },
        "does_not_append_champion_history": {
          "type": "boolean"
        },
        "does_not_execute_promote_command": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "approval_does_not_promote": {
          "type": "boolean"
        },
        "promotion_still_requires_explicit_command": {
          "type": "boolean"
        }
      }
    }
  }
}
