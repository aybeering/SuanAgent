{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Champion Promotion Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "candidate_run_id",
    "base_run_id",
    "experiments_dir",
    "status",
    "ok",
    "promoted",
    "approval_path",
    "approval_sha256",
    "source_dry_run_path",
    "source_dry_run_sha256",
    "evidence_checks",
    "comparison",
    "promotion_result",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "champion_promotion_receipt_v1"
      ]
    },
    "candidate_run_id": {
      "type": "string",
      "minLength": 1
    },
    "base_run_id": {
      "type": "string"
    },
    "experiments_dir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "promoted",
        "blocked"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "promoted": {
      "type": "boolean"
    },
    "approval_path": {
      "type": "string"
    },
    "approval_sha256": {
      "type": "string"
    },
    "source_dry_run_path": {
      "type": "string"
    },
    "source_dry_run_sha256": {
      "type": "string"
    },
    "evidence_checks": {
      "type": "object",
      "required": [
        "ok",
        "blockers",
        "approval_schema_errors",
        "dry_run_schema_errors",
        "expected_command",
        "reviewed_command",
        "current_champion_run_id"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_schema_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dry_run_schema_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expected_command": {
          "type": "string"
        },
        "reviewed_command": {
          "type": "string"
        },
        "current_champion_run_id": {
          "type": "string"
        }
      }
    },
    "comparison": {
      "type": "object"
    },
    "promotion_result": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "required": [
        "requires_approval_artifact",
        "requires_approval_recorded",
        "requires_command_digest_match",
        "requires_source_dry_run_digest_match",
        "requires_current_champion_match",
        "requires_current_comparison_recommendation",
        "writes_only_champion_registry_and_history",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance"
      ],
      "properties": {
        "requires_approval_artifact": {
          "type": "boolean"
        },
        "requires_approval_recorded": {
          "type": "boolean"
        },
        "requires_command_digest_match": {
          "type": "boolean"
        },
        "requires_source_dry_run_digest_match": {
          "type": "boolean"
        },
        "requires_current_champion_match": {
          "type": "boolean"
        },
        "requires_current_comparison_recommendation": {
          "type": "boolean"
        },
        "writes_only_champion_registry_and_history": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  }
}
