{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Champion Terminal Status",
  "type": "object",
  "required": [
    "schema_version",
    "exists",
    "champion_path",
    "lineage_summary",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "champion_status_v1"
      ]
    },
    "exists": {
      "type": "boolean"
    },
    "champion_path": {
      "type": "string",
      "minLength": 1
    },
    "champion": {
      "type": "object"
    },
    "lineage_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "ok",
        "current_champion_exists",
        "current_champion_run_id",
        "event_count",
        "parse_error_count",
        "approved_receipt_count",
        "legacy_direct_count",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "champion_lineage_summary_v1"
          ]
        },
        "ok": {
          "type": "boolean"
        },
        "current_champion_exists": {
          "type": "boolean"
        },
        "current_champion_run_id": {
          "type": "string"
        },
        "last_history_champion_run_id": {
          "type": "string"
        },
        "current_champion_matches_last_history": {
          "type": "boolean"
        },
        "event_count": {
          "type": "integer",
          "minimum": 0
        },
        "parse_error_count": {
          "type": "integer",
          "minimum": 0
        },
        "approved_receipt_count": {
          "type": "integer",
          "minimum": 0
        },
        "legacy_direct_count": {
          "type": "integer",
          "minimum": 0
        },
        "latest_promotion_source": {
          "type": "string"
        },
        "latest_champion_run_id": {
          "type": "string"
        },
        "latest_promoted_from_run_id": {
          "type": "string"
        },
        "latest_validation_ev_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "history_path": {
          "type": "string",
          "minLength": 1
        },
        "lineage_artifact_path": {
          "type": "string",
          "minLength": 1
        },
        "lineage_markdown_path": {
          "type": "string",
          "minLength": 1
        },
        "lineage_artifact_exists": {
          "type": "boolean"
        },
        "lineage_markdown_exists": {
          "type": "boolean"
        },
        "policy": {
          "type": "object"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_write_champion",
        "does_not_promote_champion",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_write_champion": {
          "type": "boolean"
        },
        "does_not_promote_champion": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  }
}
