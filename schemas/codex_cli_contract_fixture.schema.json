{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Codex CLI Contract Fixture",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "reason_codes",
    "failure_stage",
    "failure_code",
    "failure_message",
    "run_id",
    "round_id",
    "round_dir",
    "requested_attempt_id",
    "attempt_id",
    "selected_attempt_id",
    "checks",
    "artifacts",
    "contract",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "codex_cli_contract_fixture_v1"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "reason_codes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage",
          "code",
          "message"
        ],
        "properties": {
          "stage": {
            "type": "string"
          },
          "code": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "failure_stage": {
      "type": "string"
    },
    "failure_code": {
      "type": "string"
    },
    "failure_message": {
      "type": "string"
    },
    "run_id": {
      "type": "string"
    },
    "round_id": {
      "type": "string"
    },
    "round_dir": {
      "type": "string"
    },
    "requested_attempt_id": {
      "type": "string"
    },
    "attempt_id": {
      "type": "string"
    },
    "selected_attempt_id": {
      "type": "string"
    },
    "checks": {
      "type": "object",
      "required": [
        "attempt_present",
        "adapter_is_codex_cli",
        "runner_is_guarded_codex_cli",
        "intake_binding_bound",
        "intake_binding_clean",
        "stdin_prompt_sha_matches_audit",
        "fixture_stdout_validation_ok",
        "fixture_patch_present",
        "does_not_execute_codex"
      ],
      "properties": {
        "attempt_present": {
          "type": "boolean"
        },
        "adapter_is_codex_cli": {
          "type": "boolean"
        },
        "runner_is_guarded_codex_cli": {
          "type": "boolean"
        },
        "intake_binding_bound": {
          "type": "boolean"
        },
        "intake_binding_clean": {
          "type": "boolean"
        },
        "stdin_prompt_sha_matches_audit": {
          "type": "boolean"
        },
        "fixture_stdout_validation_ok": {
          "type": "boolean"
        },
        "fixture_patch_present": {
          "type": "boolean"
        },
        "does_not_execute_codex": {
          "type": "boolean"
        }
      }
    },
    "artifacts": {
      "type": "object"
    },
    "contract": {
      "type": "object",
      "required": [
        "command",
        "execution_status",
        "execution_enabled",
        "prompt_sha256",
        "audit_stdin_sha256",
        "intake_binding_status",
        "intake_binding_blocking_reasons",
        "fixture_stdout_sha256",
        "fixture_patch_sha256",
        "fixture_direction_tag"
      ],
      "properties": {
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution_status": {
          "type": "string"
        },
        "execution_enabled": {
          "type": "boolean"
        },
        "prompt_sha256": {
          "$ref": "#/$defs/sha256_or_empty"
        },
        "audit_stdin_sha256": {
          "$ref": "#/$defs/sha256_or_empty"
        },
        "intake_binding_status": {
          "type": "string"
        },
        "intake_binding_blocking_reasons": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fixture_stdout_sha256": {
          "$ref": "#/$defs/sha256_or_empty"
        },
        "fixture_patch_sha256": {
          "$ref": "#/$defs/sha256_or_empty"
        },
        "fixture_direction_tag": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "does_not_execute_codex_cli",
        "does_not_select_candidate",
        "does_not_apply_final_patch",
        "does_not_change_acceptance",
        "freezes_stdin_stdout_contract",
        "requires_guarded_codex_runner",
        "requires_intake_binding",
        "requires_prompt_hash_match",
        "requires_fixture_stdout_validation"
      ],
      "properties": {
        "does_not_execute_codex_cli": {
          "type": "boolean"
        },
        "does_not_select_candidate": {
          "type": "boolean"
        },
        "does_not_apply_final_patch": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "freezes_stdin_stdout_contract": {
          "type": "boolean"
        },
        "requires_guarded_codex_runner": {
          "type": "boolean"
        },
        "requires_intake_binding": {
          "type": "boolean"
        },
        "requires_prompt_hash_match": {
          "type": "boolean"
        },
        "requires_fixture_stdout_validation": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "sha256_or_empty": {
      "type": "string",
      "pattern": "^$|^[a-f0-9]{64}$"
    }
  }
}
