{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Codex CLI Dry Invocation Guard",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "config_path",
    "ok",
    "dry_invocation_ready",
    "execution_requested",
    "blocking_reasons",
    "checks",
    "config",
    "dry_invocation",
    "artifacts",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "codex_cli_dry_invocation_guard_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "config_path": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "dry_invocation_ready": {
      "type": "boolean"
    },
    "execution_requested": {
      "type": "boolean"
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "config_exists",
        "strategy_modifier_is_codex_cli",
        "executable_declared",
        "executable_found",
        "execute_requested",
        "prompt_is_harmless",
        "command_is_harmless",
        "sandbox_workspace_write",
        "workspace_created",
        "execution_audit_present",
        "execution_completed",
        "returncode_zero",
        "stdout_contains_expected_text",
        "mutation_guard_passed",
        "no_allowed_mutation_paths",
        "does_not_apply_patches",
        "does_not_change_acceptance"
      ]
    },
    "config": {
      "type": "object",
      "required": [
        "strategy_modifier",
        "codex_cli"
      ]
    },
    "dry_invocation": {
      "type": "object",
      "required": [
        "prompt_sha256",
        "expected_text",
        "command",
        "timeout_seconds",
        "result"
      ]
    },
    "artifacts": {
      "type": "object",
      "required": [
        "candidate_config",
        "prompt",
        "execution_audit",
        "workspace"
      ]
    },
    "policy": {
      "type": "object",
      "required": [
        "guard_only",
        "harmless_prompt_only",
        "does_not_reference_strategy_file",
        "does_not_apply_patches",
        "does_not_select_candidate",
        "does_not_change_acceptance",
        "requires_empty_mutation_allowlist",
        "requires_workspace_mutation_guard",
        "deterministic_code_keeps_acceptance_authority"
      ]
    }
  }
}
