{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Codex CLI Execution Candidate",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "ok",
    "execution_candidate_ready",
    "blocking_reasons",
    "checks",
    "source_snapshot",
    "candidate_config",
    "execution_plan",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "codex_cli_execution_candidate_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "execution_candidate_ready": {
      "type": "boolean"
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "snapshot_exists",
        "snapshot_ok",
        "snapshot_digest_present",
        "snapshot_unlocked",
        "snapshot_source_gate_hash_present",
        "candidate_config_recorded",
        "candidate_config_exists",
        "candidate_config_sha256_matches_snapshot",
        "config_binding_all_matched",
        "strategy_modifier_is_codex_cli",
        "execute_true_candidate",
        "sandbox_workspace_write",
        "workspace_root_declared",
        "target_file_is_current_strategy",
        "allowed_mutation_paths_strategy_only",
        "command_targets_strategy_only",
        "does_not_execute_codex_cli",
        "does_not_create_workspace",
        "does_not_apply_patches",
        "does_not_change_acceptance"
      ]
    },
    "source_snapshot": {
      "type": "object",
      "required": [
        "path",
        "snapshot_digest",
        "real_codex_execution_unlocked",
        "blocking_reasons",
        "file"
      ]
    },
    "candidate_config": {
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ]
    },
    "execution_plan": {
      "type": "object",
      "required": [
        "agent_name",
        "profile_name",
        "round_id",
        "attempt_id",
        "target_file",
        "allowed_mutation_paths",
        "workspace_path",
        "command",
        "timeout_seconds",
        "execution_enabled_by_this_artifact",
        "codex_cli_execute_flag"
      ]
    },
    "policy": {
      "type": "object",
      "required": [
        "candidate_only",
        "read_only",
        "requires_unlock_snapshot",
        "requires_snapshot_unlocked",
        "requires_candidate_config_hash_match",
        "does_not_execute_codex_cli",
        "does_not_create_workspace",
        "does_not_send_strategy_prompt",
        "does_not_modify_config",
        "does_not_select_candidate",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "allows_only_strategy_file_mutation",
        "deterministic_code_keeps_acceptance_authority"
      ]
    }
  }
}
