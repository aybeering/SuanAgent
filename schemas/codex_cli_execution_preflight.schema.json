{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Codex CLI Execution Preflight",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "ok",
    "blocking_errors",
    "profiles",
    "summary",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "codex_cli_execution_preflight_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "blocking_errors": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "profiles": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "profile_name",
          "adapter_name",
          "enabled",
          "execute",
          "executable",
          "requires_operator_unlock",
          "canary_exempt",
          "operator_unlock_ready",
          "blocking_errors",
          "checks",
          "operator_unlock_request"
        ]
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "profile_count",
        "real_codex_execute_profile_count",
        "real_codex_execute_profiles",
        "operator_unlock_ready_count",
        "canary_exempt_count"
      ]
    },
    "policy": {
      "type": "object",
      "required": [
        "startup_gate_only",
        "read_only",
        "blocks_real_codex_without_operator_unlock",
        "allows_checked_in_canary_fixture",
        "does_not_execute_codex_cli",
        "does_not_create_workspace",
        "does_not_send_strategy_prompt",
        "does_not_modify_config",
        "does_not_select_candidate",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "deterministic_code_keeps_acceptance_authority"
      ]
    }
  }
}
