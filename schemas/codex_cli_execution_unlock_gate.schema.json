{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Codex CLI Execution Unlock Gate",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "canary_run_dir",
    "config_path",
    "ok",
    "real_codex_execution_unlocked",
    "blocking_reasons",
    "checks",
    "config",
    "gate_status",
    "config_binding",
    "artifacts",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "codex_cli_execution_unlock_gate_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "canary_run_dir": {
      "type": "string"
    },
    "config_path": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "real_codex_execution_unlocked": {
      "type": "boolean"
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "config_exists",
        "candidate_config_sha256_present",
        "strategy_modifier_is_codex_cli",
        "execute_true_candidate",
        "replay_gate_exists",
        "replay_gate_ok",
        "replay_gate_ready",
        "enablement_gate_exists",
        "enablement_gate_ok",
        "enablement_permitted",
        "enablement_candidate_config_matches",
        "manual_approval_exists",
        "manual_approval_ok",
        "manual_approval_granted",
        "manual_approval_ready",
        "manual_approval_candidate_config_matches",
        "canary_gate_exists",
        "canary_gate_ok",
        "canary_controlled_execution_ready",
        "real_preflight_exists",
        "real_preflight_ok",
        "real_codex_cli_ready",
        "real_preflight_candidate_config_matches",
        "dry_invocation_guard_exists",
        "dry_invocation_guard_ok",
        "dry_invocation_ready",
        "dry_invocation_executed",
        "dry_invocation_candidate_config_matches",
        "candidate_config_binding_consistent",
        "does_not_execute_codex_cli",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "deterministic_code_keeps_acceptance_authority"
      ]
    },
    "config": {
      "type": "object",
      "required": [
        "strategy_modifier",
        "codex_cli"
      ]
    },
    "gate_status": {
      "type": "object",
      "required": [
        "codex_cli_replay_gate",
        "codex_cli_enablement_gate",
        "codex_cli_manual_approval",
        "codex_cli_canary_gate",
        "codex_cli_real_preflight",
        "codex_cli_dry_invocation_guard"
      ]
    },
    "config_binding": {
      "type": "object",
      "required": [
        "expected_config_path",
        "expected_config_sha256",
        "gates",
        "matched_gate_names",
        "missing_gate_names",
        "mismatched_gate_names",
        "all_matched"
      ]
    },
    "artifacts": {
      "type": "object",
      "required": [
        "candidate_config",
        "codex_cli_replay_gate",
        "codex_cli_enablement_gate",
        "codex_cli_manual_approval",
        "codex_cli_canary_gate",
        "codex_cli_real_preflight",
        "codex_cli_dry_invocation_guard"
      ]
    },
    "policy": {
      "type": "object",
      "required": [
        "unlock_gate_only",
        "read_only",
        "does_not_execute_codex_cli",
        "does_not_send_strategy_prompt",
        "does_not_modify_config",
        "does_not_select_candidate",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "requires_replay_gate",
        "requires_enablement_gate",
        "requires_manual_approval",
        "requires_controlled_canary",
        "requires_real_preflight",
        "requires_successful_dry_invocation",
        "requires_candidate_config_hash_binding",
        "deterministic_code_keeps_acceptance_authority"
      ]
    }
  }
}
