{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Codex CLI Readiness Pipeline",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "canary_run_dir",
    "config_path",
    "ok",
    "pipeline_completed",
    "final_ready",
    "readiness_status",
    "blocking_reasons",
    "steps",
    "generated_artifacts",
    "final_summary",
    "options",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "codex_cli_readiness_pipeline_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "canary_run_dir": {
      "type": "string"
    },
    "config_path": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "pipeline_completed": {
      "type": "boolean"
    },
    "final_ready": {
      "type": "boolean"
    },
    "readiness_status": {
      "type": "string",
      "enum": [
        "blocked",
        "ready_for_operator_review"
      ]
    },
    "blocking_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "step",
          "schema_version",
          "ok",
          "ready_key",
          "ready",
          "blocking_reasons",
          "artifacts"
        ]
      }
    },
    "generated_artifacts": {
      "type": "object"
    },
    "final_summary": {
      "type": "object",
      "required": [
        "path",
        "final_ready",
        "readiness_status",
        "missing_stages",
        "blocked_stages",
        "file"
      ]
    },
    "options": {
      "type": "object",
      "required": [
        "approved",
        "approved_by",
        "confirmation_phrase_matches_required",
        "preflight_timeout_seconds",
        "dry_invocation_timeout_seconds",
        "execute_dry_invocation"
      ]
    },
    "policy": {
      "type": "object",
      "required": [
        "pipeline_only",
        "read_only",
        "does_not_execute_real_codex_strategy_modification",
        "does_not_create_real_execution_workspace",
        "does_not_send_strategy_prompt",
        "does_not_modify_config",
        "does_not_select_candidate",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "requires_existing_replay_gate",
        "requires_existing_canary_gate",
        "deterministic_code_keeps_acceptance_authority"
      ]
    }
  }
}
