{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Codex CLI Replay Gate",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "ok",
    "ready_to_enable_codex_cli",
    "source_artifacts",
    "totals",
    "status_counts",
    "slots",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "codex_cli_replay_gate_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "ready_to_enable_codex_cli": {
      "type": "boolean"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "rounds",
        "codex_cli_contract_fixtures",
        "round_replays"
      ]
    },
    "totals": {
      "type": "object",
      "required": [
        "slot_count",
        "ready_count",
        "blocked_count",
        "codex_cli_slot_count"
      ],
      "properties": {
        "slot_count": {
          "type": "integer"
        },
        "ready_count": {
          "type": "integer"
        },
        "blocked_count": {
          "type": "integer"
        },
        "codex_cli_slot_count": {
          "type": "integer"
        }
      }
    },
    "status_counts": {
      "type": "object"
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slot_id",
          "run_id",
          "round_id",
          "attempt_id",
          "attempt_index",
          "profile_name",
          "agent_role",
          "adapter_name",
          "runner_name",
          "execution_enabled",
          "gate_status",
          "ready_to_enable",
          "blocking_issues",
          "requirements",
          "artifacts",
          "artifact_records",
          "evidence"
        ],
        "properties": {
          "slot_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "round_id": {
            "type": "string"
          },
          "attempt_id": {
            "type": "string"
          },
          "attempt_index": {
            "type": "integer"
          },
          "profile_name": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "runner_name": {
            "type": "string"
          },
          "execution_enabled": {
            "type": "boolean"
          },
          "gate_status": {
            "type": "string",
            "enum": [
              "ready",
              "blocked"
            ]
          },
          "ready_to_enable": {
            "type": "boolean"
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requirements": {
            "type": "object"
          },
          "artifacts": {
            "type": "object"
          },
          "artifact_records": {
            "type": "object",
            "required": [
              "agent_execution",
              "codex_cli_contract_fixture",
              "agent_output_quarantine",
              "round_replay"
            ],
            "properties": {
              "agent_execution": {
                "$ref": "#/$defs/artifact_record"
              },
              "codex_cli_contract_fixture": {
                "$ref": "#/$defs/artifact_record"
              },
              "agent_output_quarantine": {
                "$ref": "#/$defs/artifact_record"
              },
              "round_replay": {
                "$ref": "#/$defs/artifact_record"
              }
            }
          },
          "evidence": {
            "type": "object"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "gate_only",
        "does_not_execute_codex_cli",
        "does_not_select_candidate",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "requires_guarded_execution_audit",
        "requires_contract_fixture",
        "requires_quarantine",
        "requires_round_replay",
        "deterministic_code_keeps_acceptance_authority"
      ],
      "properties": {
        "gate_only": {
          "type": "boolean"
        },
        "does_not_execute_codex_cli": {
          "type": "boolean"
        },
        "does_not_select_candidate": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "requires_guarded_execution_audit": {
          "type": "boolean"
        },
        "requires_contract_fixture": {
          "type": "boolean"
        },
        "requires_quarantine": {
          "type": "boolean"
        },
        "requires_round_replay": {
          "type": "boolean"
        },
        "deterministic_code_keeps_acceptance_authority": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "artifact_record": {
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "sha256": {
          "$ref": "#/$defs/sha256_or_empty"
        }
      }
    },
    "sha256_or_empty": {
      "type": "string",
      "pattern": "^$|^[a-f0-9]{64}$"
    }
  }
}
