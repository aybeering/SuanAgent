{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Config Application Dry Run",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "source_operator_review",
    "source_config",
    "operator_intent",
    "application_gate",
    "planned_changes",
    "recommended_next_actions",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "config_application_dry_run_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "needs_operator_review",
        "no_candidate_changes",
        "no_approved_changes",
        "ready_for_manual_application",
        "application_blocked"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "source_operator_review": {
      "type": "object",
      "required": [
        "artifact_name",
        "from_artifact",
        "file"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "from_artifact": {
          "type": "boolean"
        },
        "file": {
          "$ref": "#/$defs/file_record"
        }
      }
    },
    "source_config": {
      "type": "object",
      "required": [
        "artifact_name",
        "file"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "file": {
          "$ref": "#/$defs/file_record"
        }
      }
    },
    "operator_intent": {
      "type": "object",
      "required": [
        "review_recorded",
        "decision_requested",
        "operator_id",
        "target_candidate_ids",
        "confirmation_phrase_matches"
      ],
      "properties": {
        "review_recorded": {
          "type": "boolean"
        },
        "decision_requested": {
          "type": "string"
        },
        "operator_id": {
          "type": "string"
        },
        "target_candidate_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confirmation_phrase_matches": {
          "type": "boolean"
        }
      }
    },
    "application_gate": {
      "type": "object",
      "required": [
        "eligible_for_manual_application",
        "application_blockers",
        "approved_change_count",
        "ready_change_count",
        "requires_operator_review_artifact",
        "requires_approved_operator_review",
        "requires_config_value_match",
        "config_changes_must_be_manual"
      ],
      "properties": {
        "eligible_for_manual_application": {
          "type": "boolean"
        },
        "application_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approved_change_count": {
          "type": "integer"
        },
        "ready_change_count": {
          "type": "integer"
        },
        "requires_operator_review_artifact": {
          "type": "boolean"
        },
        "requires_approved_operator_review": {
          "type": "boolean"
        },
        "requires_config_value_match": {
          "type": "boolean"
        },
        "config_changes_must_be_manual": {
          "type": "boolean"
        }
      }
    },
    "planned_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "config_path",
          "review_decision",
          "selected_for_application",
          "current_config_value",
          "reviewed_current_value",
          "proposed_value",
          "value_matches_review",
          "would_change_config",
          "ready_for_manual_edit",
          "applied",
          "requires_manual_config_edit",
          "source_artifact"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "config_path": {
            "type": "string"
          },
          "review_decision": {
            "type": "string"
          },
          "selected_for_application": {
            "type": "boolean"
          },
          "current_config_value": {},
          "reviewed_current_value": {},
          "proposed_value": {},
          "value_matches_review": {
            "type": "boolean"
          },
          "would_change_config": {
            "type": "boolean"
          },
          "ready_for_manual_edit": {
            "type": "boolean"
          },
          "applied": {
            "type": "boolean"
          },
          "requires_manual_config_edit": {
            "type": "boolean"
          },
          "source_artifact": {
            "type": "string"
          }
        }
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_write_config",
        "does_not_delete_memory",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_route_candidates",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "dry_run_only",
        "config_changes_still_require_manual_edit"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_write_config": {
          "type": "boolean"
        },
        "does_not_delete_memory": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_route_candidates": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "dry_run_only": {
          "type": "boolean"
        },
        "config_changes_still_require_manual_edit": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      }
    }
  }
}
