{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Config Application Restore Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "restored",
    "config_path",
    "config_before_sha256",
    "config_after_sha256",
    "source_preview_path",
    "source_preview_sha256",
    "source_preview_status",
    "source_receipt_path",
    "source_receipt_sha256",
    "restore_gate",
    "restored_changes",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "config_application_restore_receipt_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "restored",
        "blocked"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "restored": {
      "type": "boolean"
    },
    "config_path": {
      "type": "string"
    },
    "config_before_sha256": {
      "type": "string"
    },
    "config_after_sha256": {
      "type": "string"
    },
    "source_preview_path": {
      "type": "string"
    },
    "source_preview_sha256": {
      "type": "string"
    },
    "source_preview_status": {
      "type": "string"
    },
    "source_receipt_path": {
      "type": "string"
    },
    "source_receipt_sha256": {
      "type": "string"
    },
    "restore_gate": {
      "type": "object",
      "required": [
        "ok",
        "blockers",
        "preview_schema_errors",
        "restore_plan_count",
        "restorable_change_count"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "preview_schema_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "restore_plan_count": {
          "type": "integer"
        },
        "restorable_change_count": {
          "type": "integer"
        }
      }
    },
    "restored_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "config_path",
          "previous_value",
          "restored_value",
          "source_artifact"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "config_path": {
            "type": "string"
          },
          "previous_value": {},
          "restored_value": {},
          "restored_path_exists": {
            "type": "boolean"
          },
          "source_artifact": {
            "type": "string"
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "requires_config_application_rollback_preview",
        "requires_preview_ready",
        "requires_preview_digest_match",
        "requires_source_receipt_digest_match",
        "requires_current_config_digest_match",
        "writes_only_config",
        "does_not_delete_memory",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_route_candidates",
        "does_not_apply_patches",
        "does_not_change_acceptance"
      ],
      "properties": {
        "requires_config_application_rollback_preview": {
          "type": "boolean"
        },
        "requires_preview_ready": {
          "type": "boolean"
        },
        "requires_preview_digest_match": {
          "type": "boolean"
        },
        "requires_source_receipt_digest_match": {
          "type": "boolean"
        },
        "requires_current_config_digest_match": {
          "type": "boolean"
        },
        "writes_only_config": {
          "type": "boolean"
        },
        "does_not_delete_memory": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_route_candidates": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  }
}
