{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Config Lineage",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "current_config",
    "stages",
    "checks",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "config_lineage_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "partial",
        "blocked",
        "applied",
        "restored"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "current_config": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "stage_name",
          "artifact_path",
          "exists",
          "sha256",
          "schema_version",
          "status",
          "action_succeeded",
          "config_before_sha256",
          "config_after_sha256",
          "blockers",
          "source_links"
        ],
        "properties": {
          "stage_name": {
            "type": "string"
          },
          "artifact_path": {
            "type": "string"
          },
          "exists": {
            "type": "boolean"
          },
          "sha256": {
            "type": "string"
          },
          "schema_version": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "action_succeeded": {
            "type": "boolean"
          },
          "config_before_sha256": {
            "type": "string"
          },
          "config_after_sha256": {
            "type": "string"
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "source_links": {
            "type": "array",
            "items": {
              "type": "object",
              "required": [
                "source_name",
                "path",
                "sha256"
              ],
              "properties": {
                "source_name": {
                  "type": "string"
                },
                "path": {
                  "type": "string"
                },
                "sha256": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "ok",
        "errors",
        "stage_count",
        "existing_stage_count",
        "applied",
        "restored",
        "current_config_matches_latest_stage",
        "current_config_sha256"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "stage_count": {
          "type": "integer"
        },
        "existing_stage_count": {
          "type": "integer"
        },
        "applied": {
          "type": "boolean"
        },
        "restored": {
          "type": "boolean"
        },
        "current_config_matches_latest_stage": {
          "type": "boolean"
        },
        "current_config_sha256": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_write_config",
        "does_not_delete_memory",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_route_candidates",
        "does_not_apply_patches",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_write_config": {
          "type": "boolean"
        },
        "does_not_delete_memory": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_route_candidates": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  }
}
