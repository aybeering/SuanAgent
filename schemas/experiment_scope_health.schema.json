{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Experiment Scope Health",
  "type": "object",
  "required": [
    "schema_version",
    "repo_root",
    "experiments_dir",
    "history_path",
    "scope",
    "ok",
    "status",
    "summary",
    "component_status",
    "components",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "experiment_scope_health_v1"
      ]
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "experiments_dir": {
      "type": "string",
      "minLength": 1
    },
    "history_path": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "required": [
        "created_at_from",
        "run_selection"
      ],
      "properties": {
        "created_at_from": {
          "type": "string"
        },
        "run_selection": {
          "type": "string"
        }
      }
    },
    "ok": {
      "type": "boolean"
    },
    "status": {
      "type": "string",
      "enum": [
        "healthy",
        "unhealthy"
      ]
    },
    "summary": {
      "type": "object",
      "required": [
        "scoped_run_count",
        "artifact_failed_run_count",
        "artifact_error_count",
        "artifact_warning_count",
        "history_record_count",
        "history_failed_run_observation_count",
        "history_artifact_failure_count",
        "memory_outcome_record_count",
        "memory_failed_health_run_count",
        "memory_matched_failed_health_run_count",
        "read_error_count"
      ],
      "properties": {
        "scoped_run_count": {
          "type": "integer"
        },
        "artifact_failed_run_count": {
          "type": "integer"
        },
        "artifact_error_count": {
          "type": "integer"
        },
        "artifact_warning_count": {
          "type": "integer"
        },
        "history_record_count": {
          "type": "integer"
        },
        "history_failed_run_observation_count": {
          "type": "integer"
        },
        "history_artifact_failure_count": {
          "type": "integer"
        },
        "memory_outcome_record_count": {
          "type": "integer"
        },
        "memory_failed_health_run_count": {
          "type": "integer"
        },
        "memory_matched_failed_health_run_count": {
          "type": "integer"
        },
        "read_error_count": {
          "type": "integer"
        }
      }
    },
    "component_status": {
      "type": "object",
      "required": [
        "run_artifact_health_ok",
        "run_artifact_health_history_ok",
        "memory_diagnostics_ok",
        "history_scope_clean",
        "memory_scope_clean"
      ],
      "properties": {
        "run_artifact_health_ok": {
          "type": "boolean"
        },
        "run_artifact_health_history_ok": {
          "type": "boolean"
        },
        "memory_diagnostics_ok": {
          "type": "boolean"
        },
        "history_scope_clean": {
          "type": "boolean"
        },
        "memory_scope_clean": {
          "type": "boolean"
        }
      }
    },
    "components": {
      "type": "object",
      "required": [
        "run_artifact_health",
        "run_artifact_health_history",
        "memory_diagnostics"
      ],
      "properties": {
        "run_artifact_health": {
          "$ref": "#/$defs/run_artifact_health_component"
        },
        "run_artifact_health_history": {
          "$ref": "#/$defs/history_component"
        },
        "memory_diagnostics": {
          "$ref": "#/$defs/memory_component"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "reads_outcome_memory_only",
        "reads_artifact_health_history_only",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "does_not_route_agents",
        "strict_mode_required_for_nonzero_exit"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "reads_outcome_memory_only": {
          "type": "boolean"
        },
        "reads_artifact_health_history_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "strict_mode_required_for_nonzero_exit": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "integer_totals": {
      "type": "object"
    },
    "scope": {
      "type": "object"
    },
    "run_artifact_health_component": {
      "type": "object",
      "required": [
        "schema_version",
        "ok",
        "selection",
        "totals",
        "failed_run_ids"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "selection": {
          "type": "object"
        },
        "totals": {
          "$ref": "#/$defs/integer_totals"
        },
        "failed_run_ids": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "history_component": {
      "type": "object",
      "required": [
        "schema_version",
        "ok",
        "scope",
        "totals",
        "failed_run_ids",
        "artifact_failure_names",
        "read_errors"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "totals": {
          "$ref": "#/$defs/integer_totals"
        },
        "failed_run_ids": {
          "$ref": "#/$defs/string_array"
        },
        "artifact_failure_names": {
          "$ref": "#/$defs/string_array"
        },
        "read_errors": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "memory_component": {
      "type": "object",
      "required": [
        "schema_version",
        "ok",
        "scope",
        "totals",
        "matched_failed_run_ids",
        "unmatched_failed_health_run_ids",
        "read_errors"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "totals": {
          "$ref": "#/$defs/integer_totals"
        },
        "matched_failed_run_ids": {
          "$ref": "#/$defs/string_array"
        },
        "unmatched_failed_health_run_ids": {
          "$ref": "#/$defs/string_array"
        },
        "read_errors": {
          "$ref": "#/$defs/string_array"
        }
      }
    }
  }
}
