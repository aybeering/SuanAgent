{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Experiment Summary Dashboard",
  "type": "object",
  "required": [
    "schema_version",
    "total_runs",
    "recent_limit",
    "latest_run",
    "latest_accepted_run",
    "latest_rejected_run",
    "recent_runs",
    "recent_failure_codes",
    "top_recent_failure_code",
    "recent_outcome_categories",
    "top_recent_outcome_category",
    "champion_gap",
    "operator_home_entry",
    "operator_next_command_entry",
    "watchlist",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "experiment_summary_dashboard_v1"
      ]
    },
    "total_runs": {
      "type": "integer"
    },
    "recent_limit": {
      "type": "integer"
    },
    "latest_run": {
      "$ref": "#/$defs/optional_record_row"
    },
    "latest_accepted_run": {
      "$ref": "#/$defs/optional_record_row"
    },
    "latest_rejected_run": {
      "$ref": "#/$defs/optional_record_row"
    },
    "recent_runs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recent_run_row"
      }
    },
    "recent_failure_codes": {
      "type": "object"
    },
    "top_recent_failure_code": {
      "type": "string"
    },
    "recent_outcome_categories": {
      "type": "object"
    },
    "top_recent_outcome_category": {
      "type": "string"
    },
    "champion_gap": {
      "$ref": "#/$defs/champion_gap"
    },
    "operator_home_entry": {
      "$ref": "#/$defs/operator_home_entry"
    },
    "operator_next_command_entry": {
      "$ref": "#/$defs/operator_next_command_entry"
    },
    "watchlist": {
      "$ref": "#/$defs/watchlist"
    },
    "policy": {
      "$ref": "#/$defs/dashboard_policy"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "optional_record_row": {
      "type": [
        "object",
        "null"
      ],
      "required": [
        "run_id",
        "kind",
        "status",
        "created_at"
      ],
      "properties": {
        "run_id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        }
      }
    },
    "recent_run_row": {
      "type": "object",
      "required": [
        "run_id",
        "kind",
        "status",
        "artifact_ok",
        "accepted",
        "validation_ev_delta",
        "best_round",
        "accepted_round",
        "completed_rounds",
        "stop_reason",
        "failure_code",
        "failure_stage",
        "outcome_category",
        "outcome_primary_code",
        "outcome_primary_stage",
        "selected_direction_tag",
        "summary"
      ],
      "properties": {
        "run_id": {
          "type": "string"
        },
        "kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "artifact_ok": {
          "type": "boolean"
        },
        "accepted": {
          "type": "boolean"
        },
        "validation_ev_delta": {
          "type": "number"
        },
        "best_round": {
          "type": "string"
        },
        "accepted_round": {
          "type": [
            "string",
            "integer",
            "null"
          ]
        },
        "completed_rounds": {
          "type": "integer"
        },
        "stop_reason": {
          "type": "string"
        },
        "failure_code": {
          "type": "string"
        },
        "failure_stage": {
          "type": "string"
        },
        "outcome_category": {
          "type": "string"
        },
        "outcome_primary_code": {
          "type": "string"
        },
        "outcome_primary_stage": {
          "type": "string"
        },
        "selected_direction_tag": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "champion_gap": {
      "type": "object",
      "required": [
        "active",
        "status",
        "champion_run_id",
        "comparison_run_id",
        "gap_to_champion"
      ],
      "properties": {
        "active": {
          "type": "boolean"
        },
        "status": {
          "type": "string",
          "enum": [
            "no_champion",
            "no_comparison_run",
            "best_run_is_champion",
            "best_run_beats_champion",
            "best_run_trails_champion",
            "best_run_ties_champion"
          ]
        },
        "champion_run_id": {
          "type": "string"
        },
        "comparison_run_id": {
          "type": "string"
        },
        "champion_validation_ev_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "comparison_validation_ev_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "gap_to_champion": {
          "type": [
            "number",
            "null"
          ]
        }
      }
    },
    "operator_home_entry": {
      "type": "object",
      "required": [
        "schema_version",
        "available",
        "reason",
        "run_id",
        "run_kind",
        "status",
        "primary_focus",
        "action_step",
        "codex_unlock_runbook_status",
        "codex_preflight_next_step",
        "codex_intake_readiness_status",
        "source_views_sha256",
        "next_command_label",
        "next_command",
        "next_command_sha256",
        "next_command_status",
        "next_command_blocked",
        "next_command_blocker_count",
        "next_command_first_blocker",
        "next_command_operator_hint",
        "next_command_boundary",
        "next_command_writes_artifact",
        "next_command_requires_explicit_operator_invocation",
        "next_command_requires_operator_approval",
        "next_command_records_operator_approval",
        "next_command_uses_guarded_executor",
        "next_command_is_hint_only",
        "command_label",
        "command",
        "command_sha256",
        "command_boundary",
        "terminal_only",
        "artifact_created",
        "command_is_hint_only",
        "artifact_health_history_status",
        "artifact_health_history_ok",
        "artifact_health_history_record_count",
        "artifact_health_history_records_with_failures",
        "artifact_health_history_failed_run_observation_count",
        "artifact_health_history_artifact_failure_count",
        "artifact_health_history_round_replay_manifest_drift_observation_count",
        "artifact_health_history_read_error_count",
        "artifact_health_history_latest_recorded_at",
        "artifact_health_history_latest_failed_count",
        "artifact_health_history_latest_round_replay_manifest_drift_count",
        "artifact_health_history_latest_failed_run_ids",
        "artifact_health_history_review_command_label",
        "artifact_health_history_review_command",
        "artifact_health_history_review_command_sha256",
        "source"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "experiment_operator_home_entry_v1"
          ]
        },
        "available": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "enum": [
            "no_runs",
            "latest_run_not_iteration",
            "latest_iteration_run",
            "latest_iteration_operator_home_missing"
          ]
        },
        "run_id": {
          "type": "string"
        },
        "run_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "primary_focus": {
          "type": "string"
        },
        "action_step": {
          "type": "string"
        },
        "codex_unlock_runbook_status": {
          "type": "string"
        },
        "codex_preflight_next_step": {
          "type": "string"
        },
        "codex_intake_readiness_status": {
          "type": "string"
        },
        "source_views_sha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "next_command_label": {
          "type": "string"
        },
        "next_command": {
          "type": "string"
        },
        "next_command_sha256": {
          "type": "string"
        },
        "next_command_status": {
          "type": "string"
        },
        "next_command_blocked": {
          "type": "boolean"
        },
        "next_command_blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "next_command_first_blocker": {
          "type": "string"
        },
        "next_command_operator_hint": {
          "type": "string"
        },
        "next_command_boundary": {
          "type": "string"
        },
        "next_command_writes_artifact": {
          "type": "string"
        },
        "next_command_requires_explicit_operator_invocation": {
          "type": "boolean"
        },
        "next_command_requires_operator_approval": {
          "type": "boolean"
        },
        "next_command_records_operator_approval": {
          "type": "boolean"
        },
        "next_command_uses_guarded_executor": {
          "type": "boolean"
        },
        "next_command_is_hint_only": {
          "type": "boolean"
        },
        "command_label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "command_sha256": {
          "type": "string"
        },
        "command_boundary": {
          "type": "string"
        },
        "terminal_only": {
          "type": "boolean"
        },
        "artifact_created": {
          "type": "boolean"
        },
        "command_is_hint_only": {
          "type": "boolean"
        },
        "artifact_health_history_status": {
          "type": "string",
          "enum": [
            "available",
            "empty",
            "read_errors",
            "replay_manifest_drift_observed"
          ]
        },
        "artifact_health_history_ok": {
          "type": "boolean"
        },
        "artifact_health_history_record_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_records_with_failures": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_failed_run_observation_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_artifact_failure_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_round_replay_manifest_drift_observation_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_read_error_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_latest_recorded_at": {
          "type": "string"
        },
        "artifact_health_history_latest_failed_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_latest_round_replay_manifest_drift_count": {
          "type": "integer",
          "minimum": 0
        },
        "artifact_health_history_latest_failed_run_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact_health_history_review_command_label": {
          "type": "string"
        },
        "artifact_health_history_review_command": {
          "type": "string"
        },
        "artifact_health_history_review_command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "source": {
          "type": "string"
        }
      }
    },
    "operator_next_command_entry": {
      "type": "object",
      "required": [
        "schema_version",
        "available",
        "reason",
        "run_id",
        "run_kind",
        "status",
        "blocked",
        "blocker_count",
        "operator_hint",
        "can_invoke_selected_command",
        "navigation_summary",
        "first_blocker",
        "next_step",
        "codex_next_step",
        "codex_preflight_next_step",
        "command_label",
        "command",
        "command_sha256",
        "command_boundary",
        "terminal_only",
        "artifact_created",
        "command_is_hint_only",
        "source_home_command",
        "source_home_command_sha256",
        "source_home_source_views_sha256",
        "selection_source",
        "selected_command_label",
        "selected_command",
        "selected_command_sha256",
        "selected_command_status",
        "selected_command_boundary",
        "selected_command_writes_artifact",
        "selected_command_requires_explicit_operator_invocation",
        "selected_command_requires_operator_approval",
        "selected_command_records_operator_approval",
        "selected_command_uses_guarded_executor",
        "selected_command_is_hint_only"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "experiment_operator_next_command_entry_v1"
          ]
        },
        "available": {
          "type": "boolean"
        },
        "reason": {
          "type": "string",
          "enum": [
            "no_runs",
            "not_iteration_run",
            "operator_home_unavailable",
            "latest_run_not_iteration",
            "latest_iteration_operator_home_missing",
            "latest_iteration_run",
            "iteration_run"
          ]
        },
        "run_id": {
          "type": "string"
        },
        "run_kind": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "blocked": {
          "type": "boolean"
        },
        "blocker_count": {
          "type": "integer",
          "minimum": 0
        },
        "operator_hint": {
          "type": "string"
        },
        "can_invoke_selected_command": {
          "type": "boolean"
        },
        "navigation_summary": {
          "type": "string"
        },
        "first_blocker": {
          "type": "string"
        },
        "next_step": {
          "type": "string"
        },
        "codex_next_step": {
          "type": "string"
        },
        "codex_preflight_next_step": {
          "type": "string"
        },
        "command_label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "command_sha256": {
          "type": "string"
        },
        "command_boundary": {
          "type": "string"
        },
        "terminal_only": {
          "type": "boolean"
        },
        "artifact_created": {
          "type": "boolean"
        },
        "command_is_hint_only": {
          "type": "boolean"
        },
        "source_home_command": {
          "type": "string"
        },
        "source_home_command_sha256": {
          "type": "string"
        },
        "source_home_source_views_sha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        },
        "selection_source": {
          "type": "string"
        },
        "selected_command_label": {
          "type": "string"
        },
        "selected_command": {
          "type": "string"
        },
        "selected_command_sha256": {
          "type": "string"
        },
        "selected_command_status": {
          "type": "string"
        },
        "selected_command_boundary": {
          "type": "string"
        },
        "selected_command_writes_artifact": {
          "type": "string"
        },
        "selected_command_requires_explicit_operator_invocation": {
          "type": "boolean"
        },
        "selected_command_requires_operator_approval": {
          "type": "boolean"
        },
        "selected_command_records_operator_approval": {
          "type": "boolean"
        },
        "selected_command_uses_guarded_executor": {
          "type": "boolean"
        },
        "selected_command_is_hint_only": {
          "type": "boolean"
        }
      }
    },
    "watchlist": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "alert_count",
        "severity_counts",
        "alerts",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "experiment_watchlist_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "clean",
            "informational",
            "attention",
            "critical"
          ]
        },
        "alert_count": {
          "type": "integer"
        },
        "severity_counts": {
          "$ref": "#/$defs/severity_counts"
        },
        "alerts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/watch_alert"
          }
        },
        "policy": {
          "$ref": "#/$defs/watchlist_policy"
        }
      }
    },
    "severity_counts": {
      "type": "object",
      "required": [
        "critical",
        "warning",
        "info"
      ],
      "properties": {
        "critical": {
          "type": "integer"
        },
        "warning": {
          "type": "integer"
        },
        "info": {
          "type": "integer"
        }
      }
    },
    "watch_alert": {
      "type": "object",
      "required": [
        "severity",
        "code",
        "title",
        "detail",
        "run_id",
        "review_command_label",
        "review_command",
        "review_command_sha256",
        "review_command_boundary",
        "review_command_is_hint_only"
      ],
      "properties": {
        "severity": {
          "type": "string",
          "enum": [
            "critical",
            "warning",
            "info"
          ]
        },
        "code": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        },
        "run_id": {
          "type": "string"
        },
        "review_command_label": {
          "type": "string"
        },
        "review_command": {
          "type": "string",
          "pattern": "^(python -m orchestrator\\.experiments (list|leaderboard|memory|health-history|champion) --markdown|python -m orchestrator\\.experiments (diagnose|validate) [A-Za-z0-9_.:-]+ --markdown)$"
        },
        "review_command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "review_command_boundary": {
          "type": "string",
          "enum": [
            "read_only_inspection"
          ]
        },
        "review_command_is_hint_only": {
          "type": "boolean"
        }
      }
    },
    "dashboard_policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_apply_patches",
        "does_not_promote_champion",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_promote_champion": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    },
    "watchlist_policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_apply_patches",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  }
}
