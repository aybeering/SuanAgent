{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent External Agent Sandbox Drill",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "ok",
    "source_artifacts",
    "totals",
    "status_counts",
    "slots",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "external_agent_sandbox_drill_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "ok": {
      "type": "boolean"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "rounds",
        "round_records",
        "executor_reports",
        "executor_report_records"
      ],
      "properties": {
        "rounds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "round_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_record"
          }
        },
        "executor_reports": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "executor_report_records": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/file_record"
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "slot_count",
        "external_slot_count",
        "dry_run_only_count",
        "subprocess_executed_count",
        "blocked_count"
      ],
      "properties": {
        "slot_count": {
          "type": "integer"
        },
        "external_slot_count": {
          "type": "integer"
        },
        "dry_run_only_count": {
          "type": "integer"
        },
        "subprocess_executed_count": {
          "type": "integer"
        },
        "blocked_count": {
          "type": "integer"
        }
      }
    },
    "status_counts": {
      "type": "object"
    },
    "slots": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "slot_id",
          "run_id",
          "round_id",
          "attempt_id",
          "attempt_index",
          "queue_role",
          "profile_name",
          "agent_role",
          "adapter_name",
          "runner_name",
          "external_slot",
          "execution_enabled",
          "dry_run_only",
          "subprocess_executed",
          "sandbox_status",
          "sandbox_ok",
          "blocking_issues",
          "requirements",
          "command",
          "workspace",
          "execution_audit",
          "io_paths"
        ],
        "properties": {
          "slot_id": {
            "type": "string"
          },
          "run_id": {
            "type": "string"
          },
          "round_id": {
            "type": "string"
          },
          "attempt_id": {
            "type": "string"
          },
          "attempt_index": {
            "type": "integer"
          },
          "queue_role": {
            "type": "string"
          },
          "profile_name": {
            "type": "string"
          },
          "agent_role": {
            "type": "string"
          },
          "adapter_name": {
            "type": "string"
          },
          "runner_name": {
            "type": "string"
          },
          "external_slot": {
            "type": "boolean"
          },
          "execution_enabled": {
            "type": "boolean"
          },
          "dry_run_only": {
            "type": "boolean"
          },
          "subprocess_executed": {
            "type": "boolean"
          },
          "sandbox_status": {
            "type": "string"
          },
          "sandbox_ok": {
            "type": "boolean"
          },
          "blocking_issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "requirements": {
            "type": "object"
          },
          "command": {
            "type": "object",
            "required": [
              "source",
              "argv",
              "argc",
              "argv_sha256"
            ],
            "properties": {
              "source": {
                "type": "string"
              },
              "argv": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "argc": {
                "type": "integer"
              },
              "argv_sha256": {
                "type": "string",
                "pattern": "^$|^[0-9a-f]{64}$"
              }
            }
          },
          "workspace": {
            "type": "object",
            "required": [
              "expected_workspace_path",
              "manifest_path",
              "manifest_sha256",
              "manifest_workspace_path",
              "allowed_mutation_paths"
            ],
            "properties": {
              "expected_workspace_path": {
                "type": "string"
              },
              "manifest_path": {
                "type": "string"
              },
              "manifest_sha256": {
                "type": "string",
                "pattern": "^$|^[0-9a-f]{64}$"
              },
              "manifest_workspace_path": {
                "type": "string"
              },
              "allowed_mutation_paths": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          },
          "execution_audit": {
            "type": "object",
            "required": [
              "path",
              "artifact_sha256",
              "status",
              "returncode",
              "mutation_guard_passed"
            ],
            "properties": {
              "path": {
                "type": "string"
              },
              "artifact_sha256": {
                "type": "string",
                "pattern": "^$|^[0-9a-f]{64}$"
              },
              "status": {
                "type": "string"
              },
              "returncode": {},
              "mutation_guard_passed": {
                "type": "boolean"
              }
            }
          },
          "io_paths": {
            "type": "object",
            "required": [
              "round_agent_input",
              "round_agent_input_sha256",
              "attempt_agent_input",
              "attempt_agent_input_sha256",
              "input_bundle",
              "input_bundle_sha256",
              "round_output_files",
              "round_output_file_records"
            ],
            "properties": {
              "round_agent_input": {
                "type": "string"
              },
              "round_agent_input_sha256": {
                "type": "string",
                "pattern": "^$|^[0-9a-f]{64}$"
              },
              "attempt_agent_input": {
                "type": "string"
              },
              "attempt_agent_input_sha256": {
                "type": "string",
                "pattern": "^$|^[0-9a-f]{64}$"
              },
              "input_bundle": {
                "type": "string"
              },
              "input_bundle_sha256": {
                "type": "string",
                "pattern": "^$|^[0-9a-f]{64}$"
              },
              "round_output_files": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "round_output_file_records": {
                "type": "array",
                "items": {
                  "$ref": "#/$defs/file_record"
                }
              }
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "sandbox_drill_only",
        "does_not_execute_agents",
        "does_not_apply_patches",
        "does_not_select_candidate",
        "does_not_change_acceptance",
        "deterministic_code_keeps_acceptance_authority"
      ],
      "properties": {
        "sandbox_drill_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_select_candidate": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "deterministic_code_keeps_acceptance_authority": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string",
          "pattern": "^$|^[0-9a-f]{64}$"
        }
      }
    }
  }
}
