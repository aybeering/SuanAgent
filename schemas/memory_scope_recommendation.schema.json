{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Memory Scope Recommendation",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "source",
    "source_from_artifact",
    "current_scope",
    "observed_totals",
    "candidate_scopes",
    "recommendation",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "memory_scope_recommendation_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "source": {
      "$ref": "#/$defs/file_record"
    },
    "source_from_artifact": {
      "type": "boolean"
    },
    "current_scope": {
      "type": "object",
      "required": [
        "created_at_from",
        "recent_record_limit",
        "uses_full_history"
      ],
      "properties": {
        "created_at_from": {
          "type": "string"
        },
        "recent_record_limit": {
          "type": "integer"
        },
        "uses_full_history": {
          "type": "boolean"
        }
      }
    },
    "observed_totals": {
      "type": "object",
      "required": [
        "total_record_count",
        "active_record_count",
        "active_failed_count",
        "patch_block_count",
        "direction_block_count",
        "overblocked_patch_count"
      ],
      "properties": {
        "total_record_count": {
          "type": "integer"
        },
        "active_record_count": {
          "type": "integer"
        },
        "active_failed_count": {
          "type": "integer"
        },
        "patch_block_count": {
          "type": "integer"
        },
        "direction_block_count": {
          "type": "integer"
        },
        "overblocked_patch_count": {
          "type": "integer"
        }
      }
    },
    "candidate_scopes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "created_at_from",
          "recent_record_limit",
          "estimated_active_record_count",
          "note"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "created_at_from": {
            "type": "string"
          },
          "recent_record_limit": {
            "type": "integer"
          },
          "estimated_active_record_count": {
            "type": "integer"
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "recommendation": {
      "type": "object",
      "required": [
        "action",
        "recommended_created_at_from",
        "recommended_recent_record_limit",
        "reason_codes",
        "confidence",
        "would_change_current_config",
        "message"
      ],
      "properties": {
        "action": {
          "type": "string",
          "enum": [
            "keep_full_history",
            "keep_current_scope",
            "set_recent_record_limit"
          ]
        },
        "recommended_created_at_from": {
          "type": "string"
        },
        "recommended_recent_record_limit": {
          "type": "integer"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ]
        },
        "would_change_current_config": {
          "type": "boolean"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_write_config",
        "does_not_delete_memory",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_route_candidates",
        "does_not_apply_patches",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_write_config": {
          "type": "boolean"
        },
        "does_not_delete_memory": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_route_candidates": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      }
    }
  }
}
