{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator Action Approval",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "source_action_plan",
    "operator_intent",
    "selected_action",
    "selected_command",
    "approval_gate",
    "recommended_next_actions",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "operator_action_approval_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "needs_action_plan",
        "ready_for_operator_approval",
        "approval_blocked",
        "approval_recorded"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "source_action_plan": {
      "type": "object",
      "required": [
        "artifact_name",
        "from_artifact",
        "file"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "from_artifact": {
          "type": "boolean"
        },
        "file": {
          "$ref": "#/$defs/file_record"
        }
      }
    },
    "operator_intent": {
      "type": "object",
      "required": [
        "approval_recorded",
        "explicit_approval",
        "operator_id",
        "target_action_id",
        "target_command_label",
        "required_confirmation_phrase_hash",
        "provided_confirmation_phrase_hash",
        "confirmation_phrase_matches"
      ],
      "properties": {
        "approval_recorded": {
          "type": "boolean"
        },
        "explicit_approval": {
          "type": "boolean"
        },
        "operator_id": {
          "type": "string"
        },
        "target_action_id": {
          "type": "string"
        },
        "target_command_label": {
          "type": "string"
        },
        "required_confirmation_phrase_hash": {
          "type": "string"
        },
        "provided_confirmation_phrase_hash": {
          "type": "string"
        },
        "confirmation_phrase_matches": {
          "type": "boolean"
        }
      }
    },
    "selected_action": {
      "type": "object",
      "required": [
        "action_id",
        "action_type",
        "status",
        "source_text"
      ],
      "properties": {
        "action_id": {
          "type": "string"
        },
        "action_type": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        }
      }
    },
    "selected_command": {
      "type": "object",
      "required": [
        "label",
        "command",
        "command_sha256",
        "computed_command_sha256",
        "command_sha256_matches",
        "expected_artifact",
        "writes_repository",
        "promotes_champion",
        "runs_backtests",
        "requires_explicit_operator_invocation",
        "executed_by_approval"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "command_sha256": {
          "type": "string"
        },
        "computed_command_sha256": {
          "type": "string"
        },
        "command_sha256_matches": {
          "type": "boolean"
        },
        "expected_artifact": {
          "type": "string"
        },
        "writes_repository": {
          "type": "boolean"
        },
        "promotes_champion": {
          "type": "boolean"
        },
        "runs_backtests": {
          "type": "boolean"
        },
        "requires_explicit_operator_invocation": {
          "type": "boolean"
        },
        "executed_by_approval": {
          "type": "boolean"
        }
      }
    },
    "approval_gate": {
      "type": "object",
      "required": [
        "eligible_for_approval",
        "approval_blockers",
        "requires_action_plan",
        "requires_known_action_id",
        "requires_known_command_label",
        "requires_explicit_approval_flag",
        "requires_matching_confirmation_phrase",
        "approval_does_not_execute_command"
      ],
      "properties": {
        "eligible_for_approval": {
          "type": "boolean"
        },
        "approval_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires_action_plan": {
          "type": "boolean"
        },
        "requires_known_action_id": {
          "type": "boolean"
        },
        "requires_known_command_label": {
          "type": "boolean"
        },
        "requires_explicit_approval_flag": {
          "type": "boolean"
        },
        "requires_matching_confirmation_phrase": {
          "type": "boolean"
        },
        "approval_does_not_execute_command": {
          "type": "boolean"
        }
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_execute_commands",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_write_config",
        "does_not_promote_champion",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance",
        "approval_does_not_execute_command",
        "command_still_requires_explicit_execution"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_execute_commands": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_write_config": {
          "type": "boolean"
        },
        "does_not_promote_champion": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "approval_does_not_execute_command": {
          "type": "boolean"
        },
        "command_still_requires_explicit_execution": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "sha256",
        "byte_count"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        },
        "byte_count": {
          "type": "integer"
        }
      }
    }
  }
}
