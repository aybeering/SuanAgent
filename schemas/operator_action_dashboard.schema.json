{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator Action Dashboard",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "current_step",
    "primary_prompt",
    "source_artifacts",
    "summary",
    "timeline",
    "selected_action",
    "selected_command",
    "available_actions",
    "failure_reasons",
    "blockers",
    "recommended_commands",
    "execution_readiness",
    "path_closure",
    "authority",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "operator_action_dashboard_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "missing_action_plan",
        "pending_approval",
        "approval_blocked",
        "ready_for_execution",
        "execution_completed",
        "execution_blocked",
        "execution_failed",
        "chain_inconsistent",
        "needs_chain_repair"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "current_step": {
      "type": "string"
    },
    "primary_prompt": {
      "type": "string"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "action_plan",
        "action_approval",
        "execution_receipt",
        "action_audit"
      ],
      "properties": {
        "action_plan": {
          "$ref": "#/$defs/source_artifact"
        },
        "action_approval": {
          "$ref": "#/$defs/source_artifact"
        },
        "execution_receipt": {
          "$ref": "#/$defs/source_artifact"
        },
        "action_audit": {
          "$ref": "#/$defs/source_artifact"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "action_count",
        "command_candidate_count",
        "safe_command_count",
        "approval_present",
        "approval_recorded",
        "execution_present",
        "execution_completed",
        "chain_ok",
        "failure_reason_count",
        "first_failure_stage",
        "blocker_count"
      ],
      "properties": {
        "action_count": {
          "type": "integer"
        },
        "command_candidate_count": {
          "type": "integer"
        },
        "safe_command_count": {
          "type": "integer"
        },
        "approval_present": {
          "type": "boolean"
        },
        "approval_recorded": {
          "type": "boolean"
        },
        "execution_present": {
          "type": "boolean"
        },
        "execution_completed": {
          "type": "boolean"
        },
        "chain_ok": {
          "type": "boolean"
        },
        "failure_reason_count": {
          "type": "integer"
        },
        "first_failure_stage": {
          "type": "string"
        },
        "blocker_count": {
          "type": "integer"
        }
      }
    },
    "timeline": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/timeline_row"
      }
    },
    "selected_action": {
      "type": "object"
    },
    "selected_command": {
      "type": "object"
    },
    "available_actions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/action_row"
      }
    },
    "failure_reasons": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/failure_reason"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommended_commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommended_command"
      }
    },
    "execution_readiness": {
      "$ref": "#/$defs/execution_readiness"
    },
    "path_closure": {
      "$ref": "#/$defs/path_closure"
    },
    "authority": {
      "type": "object",
      "required": [
        "approval_required_before_execution",
        "execution_must_use_guarded_executor",
        "final_acceptance_authority",
        "dashboard_can_execute_commands",
        "dashboard_can_approve_commands",
        "dashboard_can_change_repository"
      ],
      "properties": {
        "approval_required_before_execution": {
          "type": "boolean"
        },
        "execution_must_use_guarded_executor": {
          "type": "boolean"
        },
        "final_acceptance_authority": {
          "type": "string"
        },
        "dashboard_can_execute_commands": {
          "type": "boolean"
        },
        "dashboard_can_approve_commands": {
          "type": "boolean"
        },
        "dashboard_can_change_repository": {
          "type": "boolean"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_record_approval",
        "does_not_execute_commands",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_write_config",
        "does_not_promote_champion",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_record_approval": {
          "type": "boolean"
        },
        "does_not_execute_commands": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_write_config": {
          "type": "boolean"
        },
        "does_not_promote_champion": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "source_artifact": {
      "type": "object",
      "required": [
        "artifact_name",
        "from_artifact",
        "file",
        "schema_errors"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "from_artifact": {
          "type": "boolean"
        },
        "file": {
          "$ref": "#/$defs/file_record"
        },
        "schema_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "file_record": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "sha256",
        "byte_count"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        },
        "byte_count": {
          "type": "integer"
        }
      }
    },
    "timeline_row": {
      "type": "object",
      "required": [
        "step",
        "label",
        "status",
        "artifact_path",
        "artifact_exists"
      ],
      "properties": {
        "step": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "artifact_path": {
          "type": "string"
        },
        "artifact_exists": {
          "type": "boolean"
        }
      }
    },
    "action_row": {
      "type": "object",
      "required": [
        "action_id",
        "action_type",
        "status",
        "source_text",
        "command_count",
        "safe_command_count",
        "commands"
      ],
      "properties": {
        "action_id": {
          "type": "string"
        },
        "action_type": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "source_text": {
          "type": "string"
        },
        "command_count": {
          "type": "integer"
        },
        "safe_command_count": {
          "type": "integer"
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_row"
          }
        }
      }
    },
    "command_row": {
      "type": "object",
      "required": [
        "label",
        "command",
        "command_sha256",
        "expected_artifact",
        "writes_repository",
        "promotes_champion",
        "runs_backtests",
        "allowlisted_for_guarded_execution",
        "guarded_read_only"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "command_sha256": {
          "type": "string"
        },
        "expected_artifact": {
          "type": "string"
        },
        "writes_repository": {
          "type": "boolean"
        },
        "promotes_champion": {
          "type": "boolean"
        },
        "runs_backtests": {
          "type": "boolean"
        },
        "allowlisted_for_guarded_execution": {
          "type": "boolean"
        },
        "guarded_read_only": {
          "type": "boolean"
        }
      }
    },
    "recommended_command": {
      "type": "object",
      "required": [
        "label",
        "command",
        "command_sha256",
        "reason",
        "writes_artifact",
        "boundary"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "command_sha256": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "writes_artifact": {
          "type": "string"
        },
        "boundary": {
          "$ref": "#/$defs/command_boundary"
        }
      }
    },
    "command_boundary": {
      "type": "object",
      "required": [
        "boundary_type",
        "requires_explicit_operator_invocation",
        "requires_operator_approval",
        "records_operator_approval",
        "uses_guarded_executor",
        "writes_artifact",
        "executes_agents",
        "runs_backtests",
        "applies_patches",
        "changes_acceptance"
      ],
      "properties": {
        "boundary_type": {
          "type": "string",
          "enum": [
            "read_only_inspection",
            "read_only_artifact_refresh",
            "operator_approval_receipt",
            "guarded_read_only_execution"
          ]
        },
        "requires_explicit_operator_invocation": {
          "type": "boolean"
        },
        "requires_operator_approval": {
          "type": "boolean"
        },
        "records_operator_approval": {
          "type": "boolean"
        },
        "uses_guarded_executor": {
          "type": "boolean"
        },
        "writes_artifact": {
          "type": "boolean"
        },
        "executes_agents": {
          "type": "boolean"
        },
        "runs_backtests": {
          "type": "boolean"
        },
        "applies_patches": {
          "type": "boolean"
        },
        "changes_acceptance": {
          "type": "boolean"
        }
      }
    },
    "execution_readiness": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "ready",
        "reason",
        "current_step",
        "next_command_label",
        "next_command_boundary",
        "requires_operator_approval",
        "uses_guarded_executor",
        "selected_command_label",
        "selected_command_digest_matches_plan",
        "blocker_count",
        "blockers",
        "missing_artifact_count",
        "missing_artifacts",
        "dependencies",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_action_execution_readiness_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "missing_action_plan",
            "needs_operator_approval",
            "ready_for_guarded_execution",
            "execution_completed",
            "execution_blocked",
            "execution_failed",
            "needs_chain_repair",
            "review_required",
            "blocked"
          ]
        },
        "ready": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "current_step": {
          "type": "string"
        },
        "next_command_label": {
          "type": "string"
        },
        "next_command_boundary": {
          "type": "string"
        },
        "requires_operator_approval": {
          "type": "boolean"
        },
        "uses_guarded_executor": {
          "type": "boolean"
        },
        "selected_command_label": {
          "type": "string"
        },
        "selected_command_digest_matches_plan": {
          "type": "boolean"
        },
        "blocker_count": {
          "type": "integer"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_artifact_count": {
          "type": "integer"
        },
        "missing_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "dependencies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/execution_dependency"
          }
        },
        "policy": {
          "$ref": "#/$defs/execution_readiness_policy"
        }
      }
    },
    "execution_dependency": {
      "type": "object",
      "required": [
        "artifact_name",
        "required",
        "exists",
        "passed",
        "timeline_status",
        "path"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "exists": {
          "type": "boolean"
        },
        "passed": {
          "type": "boolean"
        },
        "timeline_status": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      }
    },
    "execution_readiness_policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "does_not_execute_commands",
        "does_not_record_approval",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "does_not_execute_commands": {
          "type": "boolean"
        },
        "does_not_record_approval": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    },
    "path_closure": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "closed",
        "reason",
        "current_step",
        "completed_step_count",
        "required_step_count",
        "approval_recorded",
        "execution_completed",
        "audit_chain_ok",
        "dashboard_consistency_checked",
        "selected_command_label",
        "selected_command_digest_matches_plan",
        "blocker_count",
        "blockers",
        "steps",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_action_path_closure_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "missing_action_plan",
            "awaiting_operator_approval",
            "ready_for_guarded_execution",
            "closed",
            "needs_chain_repair",
            "blocked",
            "open"
          ]
        },
        "closed": {
          "type": "boolean"
        },
        "reason": {
          "type": "string"
        },
        "current_step": {
          "type": "string"
        },
        "completed_step_count": {
          "type": "integer"
        },
        "required_step_count": {
          "type": "integer"
        },
        "approval_recorded": {
          "type": "boolean"
        },
        "execution_completed": {
          "type": "boolean"
        },
        "audit_chain_ok": {
          "type": "boolean"
        },
        "dashboard_consistency_checked": {
          "type": "boolean"
        },
        "selected_command_label": {
          "type": "string"
        },
        "selected_command_digest_matches_plan": {
          "type": "boolean"
        },
        "blocker_count": {
          "type": "integer"
        },
        "blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "steps": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/path_closure_step"
          }
        },
        "policy": {
          "$ref": "#/$defs/execution_readiness_policy"
        }
      }
    },
    "path_closure_step": {
      "type": "object",
      "required": [
        "artifact_name",
        "phase",
        "required",
        "complete",
        "status",
        "path",
        "schema_error_count"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "phase": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "complete": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "path": {
          "type": "string"
        },
        "schema_error_count": {
          "type": "integer"
        }
      }
    },
    "failure_reason": {
      "type": "object",
      "required": [
        "stage",
        "code",
        "severity",
        "detail"
      ],
      "properties": {
        "stage": {
          "type": "string"
        },
        "code": {
          "type": "string"
        },
        "severity": {
          "type": "string"
        },
        "detail": {
          "type": "string"
        }
      }
    }
  }
}
