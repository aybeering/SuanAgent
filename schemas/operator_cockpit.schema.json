{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator Cockpit",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "primary_focus",
    "source_artifacts",
    "summary",
    "panels",
    "blockers",
    "codex_unlock_checklist",
    "recommended_commands",
    "authority",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "operator_cockpit_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "missing_closeout",
        "needs_operator_review",
        "action_pending",
        "promotion_pending_approval",
        "ready_for_review"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "primary_focus": {
      "type": "string"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "run_closeout",
        "config_lineage",
        "operator_action_dashboard",
        "codex_cli_execution_preflight",
        "candidate_challenger_report",
        "champion_promotion_dry_run",
        "champion_promotion_approval",
        "experiment_scope_health"
      ],
      "properties": {
        "run_closeout": {
          "$ref": "#/$defs/source_artifact"
        },
        "config_lineage": {
          "$ref": "#/$defs/source_artifact"
        },
        "operator_action_dashboard": {
          "$ref": "#/$defs/source_artifact"
        },
        "codex_cli_execution_preflight": {
          "$ref": "#/$defs/source_artifact"
        },
        "candidate_challenger_report": {
          "$ref": "#/$defs/source_artifact"
        },
        "champion_promotion_dry_run": {
          "$ref": "#/$defs/source_artifact"
        },
        "champion_promotion_approval": {
          "$ref": "#/$defs/source_artifact"
        },
        "experiment_scope_health": {
          "$ref": "#/$defs/source_artifact"
        }
      }
    },
    "summary": {
      "type": "object",
      "required": [
        "run_status",
        "artifact_health_ok",
        "scope_health_ok",
        "config_lineage_status",
        "config_lineage_ok",
        "action_status",
        "action_current_step",
        "action_safe_command_count",
        "challenger_status",
        "promotion_status",
        "promotion_would_promote",
        "promotion_approval_status",
        "promotion_approval_recorded",
        "codex_preflight_status",
        "codex_preflight_ok",
        "codex_real_execute_profile_count",
        "codex_operator_unlock_ready_count",
        "codex_preflight_blocker_count"
      ],
      "properties": {
        "run_status": {
          "type": "string"
        },
        "artifact_health_ok": {
          "type": "boolean"
        },
        "scope_health_ok": {
          "type": "boolean"
        },
        "config_lineage_status": {
          "type": "string"
        },
        "config_lineage_ok": {
          "type": "boolean"
        },
        "action_status": {
          "type": "string"
        },
        "action_current_step": {
          "type": "string"
        },
        "action_safe_command_count": {
          "type": "integer"
        },
        "challenger_status": {
          "type": "string"
        },
        "promotion_status": {
          "type": "string"
        },
        "promotion_would_promote": {
          "type": "boolean"
        },
        "promotion_approval_status": {
          "type": "string"
        },
        "promotion_approval_recorded": {
          "type": "boolean"
        },
        "codex_preflight_status": {
          "type": "string",
          "enum": [
            "missing",
            "blocked",
            "no_real_execution_profiles",
            "operator_unlock_ready"
          ]
        },
        "codex_preflight_ok": {
          "type": "boolean"
        },
        "codex_real_execute_profile_count": {
          "type": "integer"
        },
        "codex_operator_unlock_ready_count": {
          "type": "integer"
        },
        "codex_preflight_blocker_count": {
          "type": "integer"
        }
      }
    },
    "panels": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/panel"
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "codex_unlock_checklist": {
      "$ref": "#/$defs/codex_unlock_checklist"
    },
    "recommended_commands": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/recommended_command"
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "final_acceptance_authority",
        "cockpit_can_record_approval",
        "cockpit_can_execute_commands",
        "cockpit_can_write_config",
        "cockpit_can_promote_champion",
        "cockpit_can_change_acceptance"
      ],
      "properties": {
        "final_acceptance_authority": {
          "type": "string"
        },
        "cockpit_can_record_approval": {
          "type": "boolean"
        },
        "cockpit_can_execute_commands": {
          "type": "boolean"
        },
        "cockpit_can_write_config": {
          "type": "boolean"
        },
        "cockpit_can_promote_champion": {
          "type": "boolean"
        },
        "cockpit_can_change_acceptance": {
          "type": "boolean"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_record_approval",
        "does_not_execute_commands",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_write_config",
        "does_not_promote_champion",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_record_approval": {
          "type": "boolean"
        },
        "does_not_execute_commands": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_write_config": {
          "type": "boolean"
        },
        "does_not_promote_champion": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "source_artifact": {
      "type": "object",
      "required": [
        "artifact_name",
        "file",
        "schema_errors"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "file": {
          "$ref": "#/$defs/file_record"
        },
        "schema_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "file_record": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "sha256",
        "byte_count"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        },
        "byte_count": {
          "type": "integer"
        }
      }
    },
    "panel": {
      "type": "object",
      "required": [
        "panel_id",
        "title",
        "status",
        "ok",
        "artifact_path",
        "artifact_exists",
        "next_step"
      ],
      "properties": {
        "panel_id": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "artifact_path": {
          "type": "string"
        },
        "artifact_exists": {
          "type": "boolean"
        },
        "next_step": {
          "type": "string"
        }
      }
    },
    "recommended_command": {
      "type": "object",
      "required": [
        "label",
        "command",
        "reason",
        "writes_artifact"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "writes_artifact": {
          "type": "string"
        }
      }
    },
    "codex_unlock_checklist": {
      "type": "object",
      "required": [
        "status",
        "ready",
        "item_count",
        "passed_count",
        "failed_count",
        "next_step",
        "items",
        "authority"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "missing_preflight",
            "not_requested",
            "canary_exempt",
            "blocked",
            "ready"
          ]
        },
        "ready": {
          "type": "boolean"
        },
        "item_count": {
          "type": "integer"
        },
        "passed_count": {
          "type": "integer"
        },
        "failed_count": {
          "type": "integer"
        },
        "next_step": {
          "type": "string"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/codex_unlock_checklist_item"
          }
        },
        "authority": {
          "type": "object",
          "required": [
            "checklist_can_unlock_codex",
            "checklist_can_execute_codex",
            "checklist_can_create_workspace",
            "checklist_can_apply_patches",
            "checklist_can_change_acceptance"
          ],
          "properties": {
            "checklist_can_unlock_codex": {
              "type": "boolean"
            },
            "checklist_can_execute_codex": {
              "type": "boolean"
            },
            "checklist_can_create_workspace": {
              "type": "boolean"
            },
            "checklist_can_apply_patches": {
              "type": "boolean"
            },
            "checklist_can_change_acceptance": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "codex_unlock_checklist_item": {
      "type": "object",
      "required": [
        "check_id",
        "profile_name",
        "label",
        "status",
        "required",
        "passed_check_count",
        "total_check_count",
        "failed_checks",
        "evidence",
        "next_step"
      ],
      "properties": {
        "check_id": {
          "type": "string"
        },
        "profile_name": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "passed_check_count": {
          "type": "integer"
        },
        "total_check_count": {
          "type": "integer"
        },
        "failed_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "evidence": {
          "type": "string"
        },
        "next_step": {
          "type": "string"
        }
      }
    }
  }
}
