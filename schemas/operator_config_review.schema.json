{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator Config Review",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "source",
    "candidate_summary",
    "operator_intent",
    "review_gate",
    "reviewed_changes",
    "recommended_next_actions",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "operator_config_review_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "run_dir": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "needs_config_candidate",
        "no_candidate_changes",
        "ready_for_operator_review",
        "review_blocked",
        "review_recorded"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "source": {
      "type": "object",
      "required": [
        "artifact_name",
        "from_artifact",
        "file"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "from_artifact": {
          "type": "boolean"
        },
        "file": {
          "$ref": "#/$defs/file_record"
        }
      }
    },
    "candidate_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "candidate_count",
        "config_paths"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "candidate_count": {
          "type": "integer"
        },
        "config_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "operator_intent": {
      "type": "object",
      "required": [
        "review_recorded",
        "decision_requested",
        "operator_id",
        "target_candidate_ids",
        "required_approval_phrase_hash",
        "provided_confirmation_phrase_hash",
        "confirmation_phrase_matches"
      ],
      "properties": {
        "review_recorded": {
          "type": "boolean"
        },
        "decision_requested": {
          "type": "string",
          "enum": [
            "none",
            "approve",
            "reject"
          ]
        },
        "operator_id": {
          "type": "string"
        },
        "target_candidate_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_approval_phrase_hash": {
          "type": "string"
        },
        "provided_confirmation_phrase_hash": {
          "type": "string"
        },
        "confirmation_phrase_matches": {
          "type": "boolean"
        }
      }
    },
    "review_gate": {
      "type": "object",
      "required": [
        "eligible_for_review",
        "review_blockers",
        "requires_operator_review",
        "requires_matching_confirmation_phrase_for_approval",
        "config_changes_must_be_manual"
      ],
      "properties": {
        "eligible_for_review": {
          "type": "boolean"
        },
        "review_blockers": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "requires_operator_review": {
          "type": "boolean"
        },
        "requires_matching_confirmation_phrase_for_approval": {
          "type": "boolean"
        },
        "config_changes_must_be_manual": {
          "type": "boolean"
        }
      }
    },
    "reviewed_changes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "candidate_id",
          "config_path",
          "current_value",
          "proposed_value",
          "selected_for_review",
          "review_decision",
          "applied",
          "requires_manual_config_edit",
          "source_artifact"
        ],
        "properties": {
          "candidate_id": {
            "type": "string"
          },
          "config_path": {
            "type": "string"
          },
          "current_value": {},
          "proposed_value": {},
          "selected_for_review": {
            "type": "boolean"
          },
          "review_decision": {
            "type": "string",
            "enum": [
              "pending",
              "approved",
              "rejected"
            ]
          },
          "applied": {
            "type": "boolean"
          },
          "requires_manual_config_edit": {
            "type": "boolean"
          },
          "source_artifact": {
            "type": "string"
          }
        }
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_write_config",
        "does_not_delete_memory",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_route_candidates",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "review_does_not_apply_config",
        "config_changes_still_require_manual_edit"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_write_config": {
          "type": "boolean"
        },
        "does_not_delete_memory": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_route_candidates": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "review_does_not_apply_config": {
          "type": "boolean"
        },
        "config_changes_still_require_manual_edit": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "file_record": {
      "type": "object",
      "required": [
        "exists",
        "path",
        "bytes",
        "sha256"
      ],
      "properties": {
        "exists": {
          "type": "boolean"
        },
        "path": {
          "type": "string"
        },
        "bytes": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      }
    }
  }
}
