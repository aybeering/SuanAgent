{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator Home",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "headline",
    "primary_focus",
    "run_summary",
    "action_home",
    "codex_home",
    "artifact_health_history",
    "guided_path",
    "next_command",
    "review_priority",
    "command_center",
    "blockers",
    "source_views",
    "source_views_sha256",
    "authority",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["operator_home_v1"]
    },
    "run_id": {"type": "string", "minLength": 1},
    "run_dir": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": [
        "awaiting_operator_approval",
        "ready_for_guarded_execution",
        "review_ready",
        "review_required",
        "needs_operator_review",
        "blocked"
      ]
    },
    "ok": {"type": "boolean"},
    "headline": {"type": "string"},
    "primary_focus": {"type": "string"},
    "run_summary": {"$ref": "#/$defs/run_summary"},
    "action_home": {"$ref": "#/$defs/action_home"},
    "codex_home": {"$ref": "#/$defs/codex_home"},
    "artifact_health_history": {"$ref": "#/$defs/artifact_health_history"},
    "guided_path": {"type": "object"},
    "next_command": {"type": "object"},
    "review_priority": {"$ref": "#/$defs/review_priority"},
    "command_center": {
      "type": "array",
      "items": {"$ref": "#/$defs/command_row"}
    },
    "blockers": {
      "type": "array",
      "items": {"type": "string"}
    },
    "source_views": {"$ref": "#/$defs/source_views"},
    "source_views_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "authority": {"$ref": "#/$defs/authority"},
    "policy": {"$ref": "#/$defs/policy"}
  },
  "$defs": {
    "run_summary": {
      "type": "object",
      "required": [
        "run_status",
        "outcome_category",
        "primary_code",
        "artifact_health_ok",
        "scope_health_ok",
        "candidate_quality_selected_count",
        "candidate_quality_top_failure_code"
      ],
      "properties": {
        "run_status": {"type": "string"},
        "outcome_category": {"type": "string"},
        "primary_code": {"type": "string"},
        "artifact_health_ok": {"type": "boolean"},
        "scope_health_ok": {"type": "boolean"},
        "candidate_quality_selected_count": {"type": "integer"},
        "candidate_quality_top_failure_code": {"type": "string"}
      }
    },
    "action_home": {
      "type": "object",
      "required": [
        "guide_status",
        "current_step",
        "active_step_id",
        "completed_step_count",
        "step_count",
        "next_command_label",
        "next_command_status",
        "next_command_blocked",
        "next_command_blocker_count",
        "next_command_first_blocker",
        "next_command_operator_hint",
        "next_command_boundary",
        "next_command_writes_artifact",
        "next_command_requires_explicit_operator_invocation",
        "next_command_requires_operator_approval",
        "next_command_records_operator_approval",
        "next_command_uses_guarded_executor",
        "next_command_is_hint_only",
        "can_invoke_guarded_executor_now"
      ],
      "properties": {
        "guide_status": {"type": "string"},
        "current_step": {"type": "string"},
        "active_step_id": {"type": "string"},
        "completed_step_count": {"type": "integer"},
        "step_count": {"type": "integer"},
        "next_command_label": {"type": "string"},
        "next_command_status": {
          "type": "string",
          "enum": [
            "already_complete",
            "blocked_by_home_blockers",
            "ready_for_operator",
            "review_required",
            "unavailable",
            "waiting_for_prior_step"
          ]
        },
        "next_command_blocked": {"type": "boolean"},
        "next_command_blocker_count": {"type": "integer"},
        "next_command_first_blocker": {"type": "string"},
        "next_command_operator_hint": {"type": "string"},
        "next_command_boundary": {"type": "string"},
        "next_command_writes_artifact": {"type": "string"},
        "next_command_requires_explicit_operator_invocation": {"type": "boolean"},
        "next_command_requires_operator_approval": {"type": "boolean"},
        "next_command_records_operator_approval": {"type": "boolean"},
        "next_command_uses_guarded_executor": {"type": "boolean"},
        "next_command_is_hint_only": {"type": "boolean"},
        "can_invoke_guarded_executor_now": {"type": "boolean"}
      }
    },
    "codex_home": {
      "type": "object",
      "required": [
        "preflight_status",
        "preflight_next_step",
        "unlock_runbook_status",
        "unlock_runbook_ready",
        "unlock_runbook_blocked_step_count",
        "readiness_diff_status",
        "readiness_diff_ready",
        "readiness_diff_matched_count",
        "readiness_diff_drift_count",
        "readiness_diff_missing_count",
        "intake_readiness_status",
        "intake_ready",
        "intake_blocker_count",
        "intake_source",
        "bound_slot_count",
        "blocked_slot_count",
        "next_step",
        "review_command_label",
        "review_command",
        "review_command_sha256",
        "runbook_command_label",
        "runbook_command",
        "runbook_command_sha256"
      ],
      "properties": {
        "preflight_status": {"type": "string"},
        "preflight_next_step": {"type": "string"},
        "unlock_runbook_status": {"type": "string"},
        "unlock_runbook_ready": {"type": "boolean"},
        "unlock_runbook_blocked_step_count": {"type": "integer"},
        "readiness_diff_status": {"type": "string"},
        "readiness_diff_ready": {"type": "boolean"},
        "readiness_diff_matched_count": {"type": "integer"},
        "readiness_diff_drift_count": {"type": "integer"},
        "readiness_diff_missing_count": {"type": "integer"},
        "intake_readiness_status": {"type": "string"},
        "intake_ready": {"type": "boolean"},
        "intake_blocker_count": {"type": "integer"},
        "intake_source": {"type": "string"},
        "bound_slot_count": {"type": "integer"},
        "blocked_slot_count": {"type": "integer"},
        "next_step": {"type": "string"},
        "review_command_label": {"type": "string"},
        "review_command": {"type": "string"},
        "review_command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "runbook_command_label": {"type": "string"},
        "runbook_command": {"type": "string"},
        "runbook_command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "review_priority": {
      "type": "object",
      "required": [
        "priority",
        "target_panel",
        "target_panel_title",
        "command_label",
        "command",
        "command_sha256"
      ],
      "properties": {
        "priority": {"type": "string"},
        "target_panel": {"type": "string"},
        "target_panel_title": {"type": "string"},
        "command_label": {"type": "string"},
        "command": {"type": "string"},
        "command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "artifact_health_history": {
      "type": "object",
      "required": [
        "status",
        "ok",
        "history_path",
        "record_count",
        "records_with_failures",
        "failed_run_observation_count",
        "artifact_failure_count",
        "round_replay_manifest_drift_observation_count",
        "read_error_count",
        "latest_recorded_at",
        "latest_failed_count",
        "latest_round_replay_manifest_drift_count",
        "latest_failed_run_ids",
        "review_command_label",
        "review_command",
        "review_command_sha256"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "available",
            "empty",
            "read_errors",
            "replay_manifest_drift_observed"
          ]
        },
        "ok": {"type": "boolean"},
        "history_path": {"type": "string"},
        "record_count": {"type": "integer"},
        "records_with_failures": {"type": "integer"},
        "failed_run_observation_count": {"type": "integer"},
        "artifact_failure_count": {"type": "integer"},
        "round_replay_manifest_drift_observation_count": {"type": "integer"},
        "read_error_count": {"type": "integer"},
        "latest_recorded_at": {"type": "string"},
        "latest_failed_count": {"type": "integer"},
        "latest_round_replay_manifest_drift_count": {"type": "integer"},
        "latest_failed_run_ids": {
          "type": "array",
          "items": {"type": "string"}
        },
        "review_command_label": {"type": "string"},
        "review_command": {"type": "string"},
        "review_command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "command_row": {
      "type": "object",
      "required": [
        "source",
        "label",
        "command",
        "command_sha256",
        "reason",
        "boundary_type",
        "command_is_hint_only"
      ],
      "properties": {
        "source": {"type": "string"},
        "label": {"type": "string"},
        "command": {"type": "string"},
        "command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "reason": {"type": "string"},
        "boundary_type": {"type": "string"},
        "command_is_hint_only": {"type": "boolean"}
      }
    },
    "source_views": {
      "type": "object",
      "required": [
        "operator_cockpit",
        "operator_action_dashboard",
        "operator_action_plan",
        "run_closeout",
        "run_artifact_health_history",
        "operator_unlock_checklist",
        "codex_cli_unlock_runbook",
        "codex_cli_execution_readiness_diff",
        "champion_promotion_approval",
        "champion_promotion_receipt",
        "champion_lineage",
        "champion_registry",
        "champion_history"
      ],
      "properties": {
        "operator_cockpit": {"$ref": "#/$defs/file_record"},
        "operator_action_dashboard": {"$ref": "#/$defs/file_record"},
        "operator_action_plan": {"$ref": "#/$defs/file_record"},
        "run_closeout": {"$ref": "#/$defs/file_record"},
        "run_artifact_health_history": {"$ref": "#/$defs/file_record"},
        "operator_unlock_checklist": {"$ref": "#/$defs/file_record"},
        "codex_cli_unlock_runbook": {"$ref": "#/$defs/file_record"},
        "codex_cli_execution_readiness_diff": {"$ref": "#/$defs/file_record"},
        "champion_promotion_approval": {"$ref": "#/$defs/file_record"},
        "champion_promotion_receipt": {"$ref": "#/$defs/file_record"},
        "champion_lineage": {"$ref": "#/$defs/file_record"},
        "champion_registry": {"$ref": "#/$defs/file_record"},
        "champion_history": {"$ref": "#/$defs/file_record"}
      }
    },
    "file_record": {
      "type": "object",
      "required": ["path", "exists", "sha256", "byte_count"],
      "properties": {
        "path": {"type": "string"},
        "exists": {"type": "boolean"},
        "sha256": {
          "type": "string",
          "pattern": "^$|^[a-f0-9]{64}$"
        },
        "byte_count": {"type": "integer"}
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "home_can_record_approval",
        "home_can_execute_commands",
        "home_can_write_config",
        "home_can_promote_champion",
        "home_can_change_acceptance",
        "approval_must_use_operator_action_approval",
        "execution_must_use_guarded_executor"
      ],
      "properties": {
        "home_can_record_approval": {"type": "boolean"},
        "home_can_execute_commands": {"type": "boolean"},
        "home_can_write_config": {"type": "boolean"},
        "home_can_promote_champion": {"type": "boolean"},
        "home_can_change_acceptance": {"type": "boolean"},
        "approval_must_use_operator_action_approval": {"type": "boolean"},
        "execution_must_use_guarded_executor": {"type": "boolean"}
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "terminal_only",
        "does_not_record_approval",
        "does_not_execute_commands",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_write_config",
        "does_not_promote_champion",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {"type": "boolean"},
        "terminal_only": {"type": "boolean"},
        "does_not_record_approval": {"type": "boolean"},
        "does_not_execute_commands": {"type": "boolean"},
        "does_not_execute_agents": {"type": "boolean"},
        "does_not_run_backtests": {"type": "boolean"},
        "does_not_write_config": {"type": "boolean"},
        "does_not_promote_champion": {"type": "boolean"},
        "does_not_apply_patches": {"type": "boolean"},
        "does_not_route_agents": {"type": "boolean"},
        "does_not_change_acceptance": {"type": "boolean"}
      }
    }
  }
}
