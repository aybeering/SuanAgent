{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator Next Command",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ok",
    "home_status",
    "primary_focus",
    "selection_source",
    "label",
    "command",
    "command_sha256",
    "reason",
    "boundary_type",
    "writes_artifact",
    "blocked",
    "blocker_count",
    "operator_hint",
    "navigation",
    "action_step",
    "action_guide_status",
    "codex_unlock_runbook_status",
    "codex_preflight_next_step",
    "codex_intake_readiness_status",
    "safety",
    "source_home",
    "authority",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": ["operator_next_command_v1"]
    },
    "run_id": {"type": "string", "minLength": 1},
    "run_dir": {"type": "string", "minLength": 1},
    "status": {
      "type": "string",
      "enum": [
        "already_complete",
        "blocked_by_home_blockers",
        "ready_for_operator",
        "review_required",
        "unavailable",
        "waiting_for_prior_step"
      ]
    },
    "ok": {"type": "boolean"},
    "home_status": {"type": "string"},
    "primary_focus": {"type": "string"},
    "selection_source": {
      "type": "string",
      "enum": ["operator_home.next_command"]
    },
    "label": {"type": "string"},
    "command": {"type": "string"},
    "command_sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "reason": {"type": "string"},
    "boundary_type": {"type": "string"},
    "writes_artifact": {"type": "string"},
    "blocked": {"type": "boolean"},
    "blocker_count": {"type": "integer"},
    "operator_hint": {"type": "string"},
    "navigation": {"$ref": "#/$defs/navigation"},
    "action_step": {"type": "string"},
    "action_guide_status": {"type": "string"},
    "codex_unlock_runbook_status": {"type": "string"},
    "codex_preflight_next_step": {"type": "string"},
    "codex_intake_readiness_status": {"type": "string"},
    "safety": {"$ref": "#/$defs/safety"},
    "source_home": {"$ref": "#/$defs/source_home"},
    "authority": {"$ref": "#/$defs/authority"},
    "policy": {"$ref": "#/$defs/policy"}
  },
  "$defs": {
    "navigation": {
      "type": "object",
      "required": [
        "can_invoke_selected_command",
        "summary",
        "first_blocker",
        "next_step",
        "codex_next_step"
      ],
      "properties": {
        "can_invoke_selected_command": {"type": "boolean"},
        "summary": {"type": "string"},
        "first_blocker": {"type": "string"},
        "next_step": {"type": "string"},
        "codex_next_step": {"type": "string"}
      }
    },
    "safety": {
      "type": "object",
      "required": [
        "command_is_hint_only",
        "requires_explicit_operator_invocation",
        "requires_operator_approval",
        "records_operator_approval",
        "uses_guarded_executor"
      ],
      "properties": {
        "command_is_hint_only": {"type": "boolean"},
        "requires_explicit_operator_invocation": {"type": "boolean"},
        "requires_operator_approval": {"type": "boolean"},
        "records_operator_approval": {"type": "boolean"},
        "uses_guarded_executor": {"type": "boolean"}
      }
    },
    "source_home": {
      "type": "object",
      "required": [
        "schema_version",
        "terminal_only",
        "artifact_created",
        "command_is_hint_only",
        "command_label",
        "command",
        "command_sha256",
        "home_snapshot_sha256",
        "home_source_views_sha256",
        "boundary_type"
      ],
      "properties": {
        "schema_version": {"type": "string"},
        "terminal_only": {"type": "boolean"},
        "artifact_created": {"type": "boolean"},
        "command_is_hint_only": {"type": "boolean"},
        "command_label": {"type": "string"},
        "command": {"type": "string"},
        "command_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "home_snapshot_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "home_source_views_sha256": {
          "type": "string",
          "pattern": "^[0-9a-f]{64}$"
        },
        "boundary_type": {"type": "string"}
      }
    },
    "authority": {
      "type": "object",
      "required": [
        "selector_can_record_approval",
        "selector_can_execute_commands",
        "selector_can_write_config",
        "selector_can_promote_champion",
        "selector_can_change_acceptance",
        "approval_must_use_operator_action_approval",
        "execution_must_use_guarded_executor"
      ],
      "properties": {
        "selector_can_record_approval": {"type": "boolean"},
        "selector_can_execute_commands": {"type": "boolean"},
        "selector_can_write_config": {"type": "boolean"},
        "selector_can_promote_champion": {"type": "boolean"},
        "selector_can_change_acceptance": {"type": "boolean"},
        "approval_must_use_operator_action_approval": {"type": "boolean"},
        "execution_must_use_guarded_executor": {"type": "boolean"}
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "terminal_only",
        "does_not_create_artifacts",
        "does_not_record_approval",
        "does_not_execute_commands",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_write_config",
        "does_not_promote_champion",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {"type": "boolean"},
        "terminal_only": {"type": "boolean"},
        "does_not_create_artifacts": {"type": "boolean"},
        "does_not_record_approval": {"type": "boolean"},
        "does_not_execute_commands": {"type": "boolean"},
        "does_not_execute_agents": {"type": "boolean"},
        "does_not_run_backtests": {"type": "boolean"},
        "does_not_write_config": {"type": "boolean"},
        "does_not_promote_champion": {"type": "boolean"},
        "does_not_apply_patches": {"type": "boolean"},
        "does_not_route_agents": {"type": "boolean"},
        "does_not_change_acceptance": {"type": "boolean"}
      }
    }
  }
}
