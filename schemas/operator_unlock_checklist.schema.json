{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator Unlock Checklist",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "status",
    "ready",
    "item_count",
    "passed_count",
    "failed_count",
    "next_step",
    "source_artifacts",
    "navigation",
    "items",
    "authority",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "operator_unlock_checklist_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "missing_preflight",
        "not_requested",
        "canary_exempt",
        "blocked",
        "ready"
      ]
    },
    "ready": {
      "type": "boolean"
    },
    "item_count": {
      "type": "integer"
    },
    "passed_count": {
      "type": "integer"
    },
    "failed_count": {
      "type": "integer"
    },
    "next_step": {
      "type": "string"
    },
    "source_artifacts": {
      "type": "object",
      "required": [
        "codex_cli_execution_preflight"
      ],
      "properties": {
        "codex_cli_execution_preflight": {
          "$ref": "#/$defs/source_artifact"
        }
      }
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/checklist_item"
      }
    },
    "navigation": {
      "$ref": "#/$defs/navigation"
    },
    "authority": {
      "type": "object",
      "required": [
        "checklist_can_unlock_codex",
        "checklist_can_execute_codex",
        "checklist_can_create_workspace",
        "checklist_can_apply_patches",
        "checklist_can_change_acceptance"
      ],
      "properties": {
        "checklist_can_unlock_codex": {
          "type": "boolean"
        },
        "checklist_can_execute_codex": {
          "type": "boolean"
        },
        "checklist_can_create_workspace": {
          "type": "boolean"
        },
        "checklist_can_apply_patches": {
          "type": "boolean"
        },
        "checklist_can_change_acceptance": {
          "type": "boolean"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_record_unlock_approval",
        "does_not_execute_codex_cli",
        "does_not_execute_agents",
        "does_not_create_workspace",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_record_unlock_approval": {
          "type": "boolean"
        },
        "does_not_execute_codex_cli": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_create_workspace": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "source_artifact": {
      "type": "object",
      "required": [
        "artifact_name",
        "file",
        "schema_errors"
      ],
      "properties": {
        "artifact_name": {
          "type": "string"
        },
        "file": {
          "$ref": "#/$defs/file_record"
        },
        "schema_errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "file_record": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "sha256",
        "byte_count"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        },
        "byte_count": {
          "type": "integer"
        }
      }
    },
    "checklist_item": {
      "type": "object",
      "required": [
        "check_id",
        "profile_name",
        "group_id",
        "label",
        "status",
        "required",
        "passed_check_count",
        "total_check_count",
        "failed_checks",
        "blocking_reason_codes",
        "related_artifacts",
        "command_hints",
        "evidence",
        "next_step"
      ],
      "properties": {
        "check_id": {
          "type": "string"
        },
        "profile_name": {
          "type": "string"
        },
        "group_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string",
          "enum": [
            "passed",
            "failed"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "passed_check_count": {
          "type": "integer"
        },
        "total_check_count": {
          "type": "integer"
        },
        "failed_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "blocking_reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_artifacts": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "command_hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_hint"
          }
        },
        "evidence": {
          "type": "string"
        },
        "next_step": {
          "type": "string"
        }
      }
    },
    "navigation": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "ready",
        "blocking_count",
        "primary_blocker",
        "expected_artifacts",
        "blocking_items",
        "commands",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_unlock_navigation_v1"
          ]
        },
        "status": {
          "type": "string"
        },
        "ready": {
          "type": "boolean"
        },
        "blocking_count": {
          "type": "integer"
        },
        "primary_blocker": {
          "type": "string"
        },
        "expected_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/navigation_artifact"
          }
        },
        "blocking_items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/navigation_blocking_item"
          }
        },
        "commands": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_hint"
          }
        },
        "policy": {
          "$ref": "#/$defs/navigation_policy"
        }
      }
    },
    "navigation_blocking_item": {
      "type": "object",
      "required": [
        "check_id",
        "profile_name",
        "label",
        "status",
        "blocking_reason_codes",
        "failed_checks",
        "related_artifacts",
        "command_hints",
        "next_step"
      ],
      "properties": {
        "check_id": {
          "type": "string"
        },
        "profile_name": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "status": {
          "type": "string"
        },
        "blocking_reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed_checks": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "related_artifacts": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/navigation_artifact"
          }
        },
        "command_hints": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/command_hint"
          }
        },
        "next_step": {
          "type": "string"
        }
      }
    },
    "navigation_artifact": {
      "type": "object",
      "required": [
        "artifact_id",
        "label",
        "purpose",
        "required_for_real_codex_unlock",
        "json_path",
        "json_file",
        "markdown_path",
        "markdown_file",
        "write_command_label",
        "write_command"
      ],
      "properties": {
        "artifact_id": {
          "type": "string"
        },
        "label": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "required_for_real_codex_unlock": {
          "type": "boolean"
        },
        "json_path": {
          "type": "string"
        },
        "json_file": {
          "$ref": "#/$defs/file_record"
        },
        "markdown_path": {
          "type": "string"
        },
        "markdown_file": {
          "$ref": "#/$defs/file_record"
        },
        "write_command_label": {
          "type": "string"
        },
        "write_command": {
          "type": "string"
        }
      }
    },
    "command_hint": {
      "type": "object",
      "required": [
        "label",
        "artifact_id",
        "command",
        "writes_artifacts",
        "executes_codex_cli",
        "requires_explicit_operator_invocation"
      ],
      "properties": {
        "label": {
          "type": "string"
        },
        "artifact_id": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "writes_artifacts": {
          "type": "boolean"
        },
        "executes_codex_cli": {
          "type": "boolean"
        },
        "requires_explicit_operator_invocation": {
          "type": "boolean"
        }
      }
    },
    "navigation_policy": {
      "type": "object",
      "required": [
        "navigation_only",
        "commands_are_hints_only",
        "requires_explicit_operator_invocation",
        "does_not_execute_commands",
        "does_not_execute_codex_cli",
        "does_not_create_workspace",
        "does_not_apply_patches",
        "does_not_route_agents",
        "does_not_change_acceptance"
      ],
      "properties": {
        "navigation_only": {
          "type": "boolean"
        },
        "commands_are_hints_only": {
          "type": "boolean"
        },
        "requires_explicit_operator_invocation": {
          "type": "boolean"
        },
        "does_not_execute_commands": {
          "type": "boolean"
        },
        "does_not_execute_codex_cli": {
          "type": "boolean"
        },
        "does_not_create_workspace": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  }
}
