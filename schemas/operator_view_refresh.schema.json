{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Operator View Refresh Receipt",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "config_path",
    "config_source",
    "config_path_exists",
    "config_sha256",
    "config_record",
    "pre_refresh_snapshot_freshness",
    "refreshed_count",
    "refreshed_artifacts",
    "operator_summary",
    "home_summary",
    "blocker_delta",
    "refresh_effect",
    "review_summary",
    "cockpit_snapshot_freshness",
    "policy",
    "policy_summary"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "operator_view_refresh_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "config_path": {
      "type": "string"
    },
    "config_source": {
      "type": "string",
      "enum": [
        "explicit_override",
        "run_metadata"
      ]
    },
    "config_path_exists": {
      "type": "boolean"
    },
    "config_sha256": {
      "type": "string"
    },
    "config_record": {
      "$ref": "#/$defs/file_record"
    },
    "pre_refresh_snapshot_freshness": {
      "$ref": "#/$defs/snapshot_freshness"
    },
    "refreshed_count": {
      "type": "integer"
    },
    "refreshed_artifacts": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/refreshed_artifact"
      }
    },
    "operator_summary": {
      "$ref": "#/$defs/operator_summary"
    },
    "home_summary": {
      "$ref": "#/$defs/home_summary"
    },
    "blocker_delta": {
      "$ref": "#/$defs/blocker_delta"
    },
    "refresh_effect": {
      "$ref": "#/$defs/refresh_effect"
    },
    "review_summary": {
      "$ref": "#/$defs/review_summary"
    },
    "cockpit_snapshot_freshness": {
      "$ref": "#/$defs/snapshot_freshness"
    },
    "policy": {
      "$ref": "#/$defs/boolean_map"
    },
    "policy_summary": {
      "$ref": "#/$defs/policy_summary"
    }
  },
  "additionalProperties": false,
  "$defs": {
    "boolean_map": {
      "type": "object"
    },
    "next_command_source": {
      "type": "string",
      "enum": [
        "review_priority",
        "operator_digest",
        "recommended_commands_fallback",
        "none"
      ]
    },
    "command_boundary_type": {
      "type": "string",
      "enum": [
        "",
        "read_only_inspection",
        "read_only_artifact_refresh",
        "operator_approval_receipt",
        "guarded_read_only_execution"
      ]
    },
    "string_array": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "file_record": {
      "type": "object",
      "required": [
        "path",
        "relative_path",
        "exists",
        "sha256"
      ],
      "properties": {
        "path": {
          "type": "string"
        },
        "relative_path": {
          "type": "string"
        },
        "exists": {
          "type": "boolean"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "snapshot_freshness": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "ok",
        "stale_count",
        "stale_sources",
        "recommended_command"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_cockpit_snapshot_freshness_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "fresh",
            "stale",
            "stale_sources"
          ]
        },
        "ok": {
          "type": "boolean"
        },
        "stale_count": {
          "type": "integer"
        },
        "stale_sources": {
          "type": "array"
        },
        "recommended_command": {
          "type": "string"
        }
      }
    },
    "refreshed_artifact": {
      "type": "object",
      "required": [
        "artifact_name",
        "json_path",
        "markdown_path",
        "json_file",
        "markdown_file",
        "schema_version"
      ],
      "properties": {
        "artifact_name": {
          "type": "string",
          "minLength": 1
        },
        "json_path": {
          "type": "string",
          "minLength": 1
        },
        "markdown_path": {
          "type": "string",
          "minLength": 1
        },
        "json_file": {
          "$ref": "#/$defs/file_record"
        },
        "markdown_file": {
          "$ref": "#/$defs/file_record"
        },
        "schema_version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "operator_summary": {
      "type": "object",
      "required": [
        "cockpit_status",
        "cockpit_ok",
        "primary_focus",
        "action_execution_readiness_status",
        "action_execution_ready",
        "action_execution_next_command_boundary",
        "action_execution_missing_artifact_count",
        "action_path_closure_status",
        "action_path_closed",
        "action_path_completed_step_count",
        "action_path_required_step_count",
        "operator_digest_headline",
        "operator_digest_priority",
        "operator_digest_primary_reason",
        "operator_digest_target_panel_id",
        "operator_digest_target_panel_title",
        "operator_digest_target_panel_status",
        "operator_digest_next_step",
        "operator_digest_recommended_command_boundary",
        "blocker_count",
        "primary_blocker",
        "blocker_preview",
        "next_command_source",
        "next_command_label",
        "next_command",
        "next_command_reason",
        "next_command_boundary"
      ],
      "properties": {
        "cockpit_status": {
          "type": "string"
        },
        "cockpit_ok": {
          "type": "boolean"
        },
        "primary_focus": {
          "type": "string"
        },
        "action_execution_readiness_status": {
          "type": "string"
        },
        "action_execution_ready": {
          "type": "boolean"
        },
        "action_execution_next_command_boundary": {
          "$ref": "#/$defs/command_boundary_type"
        },
        "action_execution_missing_artifact_count": {
          "type": "integer"
        },
        "action_path_closure_status": {
          "type": "string"
        },
        "action_path_closed": {
          "type": "boolean"
        },
        "action_path_completed_step_count": {
          "type": "integer"
        },
        "action_path_required_step_count": {
          "type": "integer"
        },
        "operator_digest_headline": {
          "type": "string"
        },
        "operator_digest_priority": {
          "type": "string"
        },
        "operator_digest_primary_reason": {
          "type": "string"
        },
        "operator_digest_target_panel_id": {
          "type": "string"
        },
        "operator_digest_target_panel_title": {
          "type": "string"
        },
        "operator_digest_target_panel_status": {
          "type": "string"
        },
        "operator_digest_next_step": {
          "type": "string"
        },
        "operator_digest_recommended_command_boundary": {
          "$ref": "#/$defs/command_boundary_type"
        },
        "blocker_count": {
          "type": "integer"
        },
        "primary_blocker": {
          "type": "string"
        },
        "blocker_preview": {
          "$ref": "#/$defs/string_array"
        },
        "next_command_source": {
          "$ref": "#/$defs/next_command_source"
        },
        "next_command_label": {
          "type": "string"
        },
        "next_command": {
          "type": "string"
        },
        "next_command_reason": {
          "type": "string"
        },
        "next_command_boundary": {
          "$ref": "#/$defs/command_boundary_type"
        }
      }
    },
    "blocker_delta": {
      "type": "object",
      "required": [
        "schema_version",
        "before_count",
        "after_count",
        "changed",
        "added_count",
        "removed_count",
        "persisted_count",
        "added_blockers",
        "removed_blockers",
        "persisted_blocker_preview"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_view_refresh_blocker_delta_v1"
          ]
        },
        "before_count": {
          "type": "integer"
        },
        "after_count": {
          "type": "integer"
        },
        "changed": {
          "type": "boolean"
        },
        "added_count": {
          "type": "integer"
        },
        "removed_count": {
          "type": "integer"
        },
        "persisted_count": {
          "type": "integer"
        },
        "added_blockers": {
          "$ref": "#/$defs/string_array"
        },
        "removed_blockers": {
          "$ref": "#/$defs/string_array"
        },
        "persisted_blocker_preview": {
          "$ref": "#/$defs/string_array"
        }
      }
    },
    "home_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "ok",
        "headline",
        "primary_focus",
        "action_step",
        "action_guide_status",
        "codex_preflight_status",
        "codex_readiness_diff_status",
        "codex_intake_readiness_status",
        "codex_intake_ready",
        "codex_intake_blocker_count",
        "next_command_label",
        "next_command_boundary",
        "home_command_label",
        "home_command",
        "home_command_boundary",
        "home_command_is_hint_only"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_view_refresh_home_summary_v1"
          ]
        },
        "status": {
          "type": "string"
        },
        "ok": {
          "type": "boolean"
        },
        "headline": {
          "type": "string"
        },
        "primary_focus": {
          "type": "string"
        },
        "action_step": {
          "type": "string"
        },
        "action_guide_status": {
          "type": "string"
        },
        "codex_preflight_status": {
          "type": "string"
        },
        "codex_readiness_diff_status": {
          "type": "string"
        },
        "codex_intake_readiness_status": {
          "type": "string"
        },
        "codex_intake_ready": {
          "type": "boolean"
        },
        "codex_intake_blocker_count": {
          "type": "integer"
        },
        "next_command_label": {
          "type": "string"
        },
        "next_command_boundary": {
          "$ref": "#/$defs/command_boundary_type"
        },
        "home_command_label": {
          "type": "string"
        },
        "home_command": {
          "type": "string"
        },
        "home_command_boundary": {
          "$ref": "#/$defs/command_boundary_type"
        },
        "home_command_is_hint_only": {
          "type": "boolean"
        }
      }
    },
    "refresh_effect": {
      "type": "object",
      "required": [
        "schema_version",
        "status",
        "summary",
        "stale_sources_fixed",
        "blockers_changed",
        "safety_policy_ok",
        "operator_review_required",
        "post_blocker_count"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_view_refresh_effect_v1"
          ]
        },
        "status": {
          "type": "string",
          "enum": [
            "safety_policy_attention",
            "refresh_incomplete",
            "stale_sources_fixed_blockers_changed",
            "stale_sources_fixed",
            "blockers_changed",
            "refreshed_no_changes"
          ]
        },
        "summary": {
          "type": "string"
        },
        "stale_sources_fixed": {
          "type": "boolean"
        },
        "blockers_changed": {
          "type": "boolean"
        },
        "safety_policy_ok": {
          "type": "boolean"
        },
        "operator_review_required": {
          "type": "boolean"
        },
        "post_blocker_count": {
          "type": "integer"
        }
      }
    },
    "review_summary": {
      "type": "object",
      "required": [
        "schema_version",
        "required",
        "primary_reason",
        "reason_count",
        "reason_codes",
        "primary_blocker",
        "post_blocker_count",
        "next_command_source",
        "next_command_label",
        "next_command",
        "next_command_reason",
        "next_command_boundary"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "operator_view_refresh_review_summary_v1"
          ]
        },
        "required": {
          "type": "boolean"
        },
        "primary_reason": {
          "type": "string"
        },
        "reason_count": {
          "type": "integer"
        },
        "reason_codes": {
          "$ref": "#/$defs/string_array"
        },
        "primary_blocker": {
          "type": "string"
        },
        "post_blocker_count": {
          "type": "integer"
        },
        "next_command_source": {
          "$ref": "#/$defs/next_command_source"
        },
        "next_command_label": {
          "type": "string"
        },
        "next_command": {
          "type": "string"
        },
        "next_command_reason": {
          "type": "string"
        },
        "next_command_boundary": {
          "$ref": "#/$defs/command_boundary_type"
        }
      }
    },
    "policy_summary": {
      "type": "object",
      "required": [
        "ok",
        "true_count",
        "false_count",
        "false_keys"
      ],
      "properties": {
        "ok": {
          "type": "boolean"
        },
        "true_count": {
          "type": "integer"
        },
        "false_count": {
          "type": "integer"
        },
        "false_keys": {
          "$ref": "#/$defs/string_array"
        }
      }
    }
  }
}
