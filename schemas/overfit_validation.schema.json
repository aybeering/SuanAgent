{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Overfit Validation",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "round_index",
    "agent_role",
    "execution_mode",
    "implemented",
    "round_dir",
    "consumed_artifacts",
    "metric_deltas",
    "checks",
    "risk_flags",
    "recommendation",
    "produced_artifacts"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "overfit_validation_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "round_index": {
      "type": "integer"
    },
    "agent_role": {
      "type": "string",
      "enum": [
        "overfit_validator"
      ]
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "stub_contract"
      ]
    },
    "implemented": {
      "type": "boolean"
    },
    "round_dir": {
      "type": "string"
    },
    "consumed_artifacts": {
      "type": "object",
      "required": [
        "agent_role_contracts",
        "analysis_notes",
        "proposal",
        "decision",
        "train_metrics_before",
        "train_metrics_after",
        "validation_metrics_before",
        "validation_metrics_after",
        "holdout_metrics_before",
        "holdout_metrics_after"
      ],
      "properties": {
        "agent_role_contracts": {
          "type": "string"
        },
        "analysis_notes": {
          "type": "string"
        },
        "proposal": {
          "type": "string"
        },
        "decision": {
          "type": "string"
        },
        "train_metrics_before": {
          "type": "string"
        },
        "train_metrics_after": {
          "type": "string"
        },
        "validation_metrics_before": {
          "type": "string"
        },
        "validation_metrics_after": {
          "type": "string"
        },
        "holdout_metrics_before": {
          "type": "string"
        },
        "holdout_metrics_after": {
          "type": "string"
        }
      }
    },
    "metric_deltas": {
      "type": "object",
      "required": [
        "train",
        "validation",
        "holdout"
      ],
      "properties": {
        "train": {
          "type": "object"
        },
        "validation": {
          "type": "object"
        },
        "holdout": {
          "type": "object"
        }
      }
    },
    "checks": {
      "type": "object",
      "required": [
        "previous_rejected_rounds",
        "validation_holdout_ev_delta_gap",
        "decision_accepted",
        "deterministic_gate_active"
      ],
      "properties": {
        "previous_rejected_rounds": {
          "type": "integer"
        },
        "validation_holdout_ev_delta_gap": {
          "type": "number"
        },
        "decision_accepted": {
          "type": "boolean"
        },
        "deterministic_gate_active": {
          "type": "boolean"
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendation": {
      "type": "object",
      "required": [
        "action",
        "reason",
        "can_veto",
        "can_change_acceptance",
        "can_change_routing"
      ],
      "properties": {
        "action": {
          "type": "string"
        },
        "reason": {
          "type": "string"
        },
        "can_veto": {
          "type": "boolean"
        },
        "can_change_acceptance": {
          "type": "boolean"
        },
        "can_change_routing": {
          "type": "boolean"
        }
      }
    },
    "produced_artifacts": {
      "type": "object",
      "required": [
        "overfit_validation_json",
        "overfit_validation_markdown"
      ],
      "properties": {
        "overfit_validation_json": {
          "type": "string"
        },
        "overfit_validation_markdown": {
          "type": "string"
        }
      }
    }
  }
}
