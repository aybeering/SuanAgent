{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Proposal Intent",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "target_file",
    "recommended_direction",
    "avoid_directions",
    "reason",
    "evidence",
    "constraints",
    "source_artifacts",
    "strategy_search_space",
    "champion_gap"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "proposal_intent_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "round_id": {
      "type": "string"
    },
    "target_file": {
      "type": "string"
    },
    "recommended_direction": {
      "type": "string"
    },
    "avoid_directions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "source_artifacts": {
      "type": "object"
    },
    "strategy_search_space": {
      "type": "object",
      "required": [
        "schema_version",
        "direction_order",
        "fallback_direction",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "direction_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_direction": {
          "type": "string"
        },
        "policy": {
          "type": "object"
        }
      }
    },
    "champion_gap": {
      "type": "object"
    }
  }
}
