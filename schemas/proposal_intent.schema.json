{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Proposal Intent",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "target_file",
    "recommended_direction",
    "avoid_directions",
    "reason",
    "evidence",
    "constraints",
    "direction_decision_trace",
    "source_artifacts",
    "strategy_search_space",
    "champion_gap"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "proposal_intent_v1"
      ]
    },
    "run_id": {
      "type": "string"
    },
    "round_id": {
      "type": "string"
    },
    "target_file": {
      "type": "string"
    },
    "recommended_direction": {
      "type": "string"
    },
    "avoid_directions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "reason": {
      "type": "string"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "direction_decision_trace": {
      "type": "object",
      "required": [
        "schema_version",
        "selected_direction",
        "selection_reason_code",
        "default_direction",
        "fallback_direction",
        "candidate_order",
        "candidate_rows",
        "avoid_source_summary",
        "exhausted_known_directions",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "enum": [
            "direction_decision_trace_v1"
          ]
        },
        "selected_direction": {
          "type": "string"
        },
        "selection_reason_code": {
          "type": "string"
        },
        "default_direction": {
          "type": "string"
        },
        "fallback_direction": {
          "type": "string"
        },
        "candidate_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "candidate_rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "direction_tag",
              "rank",
              "selected",
              "in_avoid_directions",
              "avoid_sources",
              "reason",
              "description",
              "modifier_hint"
            ],
            "properties": {
              "direction_tag": {
                "type": "string"
              },
              "rank": {
                "type": "integer",
                "minimum": 1
              },
              "selected": {
                "type": "boolean"
              },
              "in_avoid_directions": {
                "type": "boolean"
              },
              "avoid_sources": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reason": {
                "type": "string"
              },
              "description": {
                "type": "string"
              },
              "modifier_hint": {
                "type": "string"
              }
            }
          }
        },
        "avoid_source_summary": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "exhausted_known_directions": {
          "type": "boolean"
        },
        "policy": {
          "type": "object",
          "required": [
            "advisory_only",
            "does_not_route_agents",
            "does_not_change_acceptance"
          ],
          "properties": {
            "advisory_only": {
              "type": "boolean",
              "const": true
            },
            "does_not_route_agents": {
              "type": "boolean",
              "const": true
            },
            "does_not_change_acceptance": {
              "type": "boolean",
              "const": true
            }
          }
        }
      }
    },
    "source_artifacts": {
      "type": "object"
    },
    "strategy_search_space": {
      "type": "object",
      "required": [
        "schema_version",
        "direction_order",
        "fallback_direction",
        "policy"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "direction_order": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "fallback_direction": {
          "type": "string"
        },
        "policy": {
          "type": "object"
        }
      }
    },
    "champion_gap": {
      "type": "object"
    }
  }
}
