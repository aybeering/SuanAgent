{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Run Artifact Health",
  "type": "object",
  "required": [
    "schema_version",
    "repo_root",
    "experiments_dir",
    "ok",
    "selection",
    "totals",
    "runs",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "run_artifact_health_v1"
      ]
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "experiments_dir": {
      "type": "string",
      "minLength": 1
    },
    "ok": {
      "type": "boolean"
    },
    "selection": {
      "type": "object",
      "required": [
        "mode",
        "limit",
        "requested_run_ids",
        "selected_run_ids"
      ],
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "explicit",
            "all",
            "recent"
          ]
        },
        "limit": {
          "type": "integer"
        },
        "requested_run_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "selected_run_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "run_count",
        "ok_count",
        "failed_count",
        "error_count",
        "warning_count",
        "checked_file_count",
        "rounds_checked"
      ],
      "properties": {
        "run_count": {
          "type": "integer"
        },
        "ok_count": {
          "type": "integer"
        },
        "failed_count": {
          "type": "integer"
        },
        "error_count": {
          "type": "integer"
        },
        "warning_count": {
          "type": "integer"
        },
        "checked_file_count": {
          "type": "integer"
        },
        "rounds_checked": {
          "type": "integer"
        }
      }
    },
    "runs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "run_id",
          "run_dir",
          "kind",
          "ok",
          "error_count",
          "warning_count",
          "checked_file_count",
          "rounds_checked",
          "errors",
          "warnings"
        ],
        "properties": {
          "run_id": {
            "type": "string"
          },
          "run_dir": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "ok": {
            "type": "boolean"
          },
          "error_count": {
            "type": "integer"
          },
          "warning_count": {
            "type": "integer"
          },
          "checked_file_count": {
            "type": "integer"
          },
          "rounds_checked": {
            "type": "integer"
          },
          "errors": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "warnings": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "validates_saved_artifacts_only",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "strict_mode_required_for_nonzero_exit"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "validates_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "strict_mode_required_for_nonzero_exit": {
          "type": "boolean"
        }
      }
    }
  }
}
