{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Run Closeout",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "run_dir",
    "experiments_dir",
    "status",
    "closeout_status",
    "ok",
    "summary",
    "artifacts",
    "selected_candidates",
    "top_candidates",
    "decision_record",
    "recommended_next_actions",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "run_closeout_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "run_dir": {
      "type": "string",
      "minLength": 1
    },
    "experiments_dir": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string"
    },
    "closeout_status": {
      "type": "string",
      "enum": [
        "ready_for_review",
        "needs_attention"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "summary": {
      "type": "object",
      "required": [
        "completed_rounds",
        "accepted_round",
        "stop_reason",
        "final_strategy_commit",
        "scope_health_ok",
        "scope_health_status",
        "artifact_health_history_recorded",
        "artifact_health_history_ok",
        "candidate_count",
        "selected_candidate_count",
        "research_brief_present",
        "research_brief_artifact_ok",
        "research_watchlist_status",
        "research_watchlist_alert_count",
        "research_primary_focus"
      ],
      "properties": {
        "completed_rounds": {
          "type": "integer"
        },
        "accepted_round": {
          "type": [
            "string",
            "null"
          ]
        },
        "stop_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "final_strategy_commit": {
          "type": [
            "string",
            "null"
          ]
        },
        "scope_health_ok": {
          "type": "boolean"
        },
        "scope_health_status": {
          "type": "string"
        },
        "artifact_health_history_recorded": {
          "type": "boolean"
        },
        "artifact_health_history_ok": {
          "type": "boolean"
        },
        "candidate_count": {
          "type": "integer"
        },
        "selected_candidate_count": {
          "type": "integer"
        },
        "research_brief_present": {
          "type": "boolean"
        },
        "research_brief_artifact_ok": {
          "type": "boolean"
        },
        "research_watchlist_status": {
          "type": "string"
        },
        "research_watchlist_alert_count": {
          "type": "integer"
        },
        "research_primary_focus": {
          "type": "string"
        }
      }
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "label",
          "path",
          "required",
          "present"
        ],
        "properties": {
          "label": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "required": {
            "type": "boolean"
          },
          "present": {
            "type": "boolean"
          }
        }
      }
    },
    "selected_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "top_candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/candidate"
      }
    },
    "decision_record": {
      "type": "object",
      "required": [
        "accepted",
        "accepted_round",
        "acceptance_source",
        "final_acceptance_authority",
        "agent_language_can_accept"
      ],
      "properties": {
        "accepted": {
          "type": "boolean"
        },
        "accepted_round": {
          "type": [
            "string",
            "null"
          ]
        },
        "acceptance_source": {
          "type": "string"
        },
        "final_acceptance_authority": {
          "type": "string"
        },
        "agent_language_can_accept": {
          "type": "boolean"
        }
      }
    },
    "recommended_next_actions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "reads_saved_artifacts_only",
        "does_not_execute_agents",
        "does_not_run_backtests",
        "does_not_apply_patches",
        "does_not_change_acceptance",
        "does_not_route_agents"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "reads_saved_artifacts_only": {
          "type": "boolean"
        },
        "does_not_execute_agents": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_apply_patches": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        },
        "does_not_route_agents": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "candidate": {
      "type": "object",
      "required": [
        "round_id",
        "role",
        "profile_name",
        "agent_name",
        "direction_tag",
        "selected",
        "status",
        "candidate_score",
        "quality_breakdown",
        "probe_ev_delta",
        "validation_ev_delta",
        "holdout_ev_delta",
        "selection_reason"
      ],
      "properties": {
        "round_id": {
          "type": "string"
        },
        "role": {
          "type": "string"
        },
        "profile_name": {
          "type": "string"
        },
        "agent_name": {
          "type": "string"
        },
        "direction_tag": {
          "type": "string"
        },
        "selected": {
          "type": "boolean"
        },
        "status": {
          "type": "string"
        },
        "candidate_score": {
          "type": "number"
        },
        "quality_breakdown": {
          "type": "object"
        },
        "probe_ev_delta": {
          "type": "number"
        },
        "validation_ev_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "holdout_ev_delta": {
          "type": [
            "number",
            "null"
          ]
        },
        "selection_reason": {
          "type": "string"
        }
      }
    }
  }
}
