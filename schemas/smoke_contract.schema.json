{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Smoke Command Contract",
  "type": "object",
  "required": [
    "schema_version",
    "ok",
    "repo_root",
    "source",
    "required_doc_commands",
    "required_ci_commands",
    "docs",
    "ci",
    "summary",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "smoke_contract_v1"
      ]
    },
    "ok": {
      "type": "boolean"
    },
    "repo_root": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "path",
        "ok",
        "commands",
        "errors"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "ok": {
          "type": "boolean"
        },
        "commands": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "errors": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "required_doc_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "required_ci_commands": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "docs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/path_command_report"
      }
    },
    "ci": {
      "$ref": "#/$defs/path_command_report"
    },
    "summary": {
      "type": "object",
      "required": [
        "doc_path_count",
        "required_doc_command_count",
        "required_ci_command_count",
        "missing_count"
      ],
      "properties": {
        "doc_path_count": {
          "type": "integer"
        },
        "required_doc_command_count": {
          "type": "integer"
        },
        "required_ci_command_count": {
          "type": "integer"
        },
        "missing_count": {
          "type": "integer"
        }
      }
    },
    "policy": {
      "type": "object",
      "required": [
        "inspection_only",
        "does_not_run_tests",
        "does_not_run_backtests",
        "does_not_create_experiments",
        "does_not_change_acceptance"
      ],
      "properties": {
        "inspection_only": {
          "type": "boolean"
        },
        "does_not_run_tests": {
          "type": "boolean"
        },
        "does_not_run_backtests": {
          "type": "boolean"
        },
        "does_not_create_experiments": {
          "type": "boolean"
        },
        "does_not_change_acceptance": {
          "type": "boolean"
        }
      }
    }
  },
  "$defs": {
    "path_command_report": {
      "type": "object",
      "required": [
        "path",
        "exists",
        "present_commands",
        "missing_commands"
      ],
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1
        },
        "exists": {
          "type": "boolean"
        },
        "present_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "missing_commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
