{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Visual Artifacts Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "round_index",
    "round_dir",
    "execution_mode",
    "visual_agent_enabled",
    "artifacts",
    "supporting_artifacts",
    "policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "visual_artifacts_manifest_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "round_index": {
      "type": "integer"
    },
    "round_dir": {
      "type": "string"
    },
    "execution_mode": {
      "type": "string",
      "enum": [
        "deterministic_static_artifacts"
      ]
    },
    "visual_agent_enabled": {
      "type": "boolean"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "artifact_id",
          "artifact_type",
          "path",
          "format",
          "schema_marker",
          "description",
          "exists",
          "bytes",
          "sha256",
          "external_dependencies",
          "source_files"
        ],
        "properties": {
          "artifact_id": {
            "type": "string"
          },
          "artifact_type": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "format": {
            "type": "string",
            "enum": [
              "html"
            ]
          },
          "schema_marker": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "exists": {
            "type": "boolean"
          },
          "bytes": {
            "type": "integer"
          },
          "sha256": {
            "type": "string"
          },
          "external_dependencies": {
            "type": "boolean"
          },
          "source_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "supporting_artifacts": {
      "type": "object"
    },
    "policy": {
      "type": "object",
      "required": [
        "external_network_assets_allowed",
        "visual_agent_can_change_acceptance",
        "visual_agent_can_change_routing"
      ],
      "properties": {
        "external_network_assets_allowed": {
          "type": "boolean"
        },
        "visual_agent_can_change_acceptance": {
          "type": "boolean"
        },
        "visual_agent_can_change_routing": {
          "type": "boolean"
        }
      }
    }
  }
}
