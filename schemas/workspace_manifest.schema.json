{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SuanAgent Isolated Workspace Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "round_id",
    "attempt_id",
    "profile_name",
    "adapter_name",
    "profile_workspace_slug",
    "agent_name",
    "execution_enabled",
    "source_repo_root",
    "workspace_path",
    "include_dirs",
    "include_files",
    "initial_snapshot",
    "mutation_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "enum": [
        "workspace_manifest_v1"
      ]
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "round_id": {
      "type": "string",
      "minLength": 1
    },
    "attempt_id": {
      "type": "string"
    },
    "profile_name": {
      "type": "string"
    },
    "adapter_name": {
      "type": "string"
    },
    "profile_workspace_slug": {
      "type": "string"
    },
    "agent_name": {
      "type": "string",
      "minLength": 1
    },
    "execution_enabled": {
      "type": "boolean"
    },
    "source_repo_root": {
      "type": "string"
    },
    "workspace_path": {
      "type": "string"
    },
    "include_dirs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "include_files": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "initial_snapshot": {
      "type": "object",
      "required": [
        "file_count",
        "sha256"
      ],
      "properties": {
        "file_count": {
          "type": "integer"
        },
        "sha256": {
          "type": "string"
        }
      }
    },
    "mutation_policy": {
      "type": "object",
      "required": [
        "allowed_paths",
        "reject_unlisted_changes"
      ],
      "properties": {
        "allowed_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "reject_unlisted_changes": {
          "type": "boolean"
        }
      }
    }
  }
}
